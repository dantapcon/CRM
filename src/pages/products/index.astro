---
import CRMLayout from '../../layouts/CRMLayout.astro';

const products = [
  { id:1,  code:'PRD-001',  name:'CRM Enterprise Suite',       cat:'Software',    price:'$2,400',  cost:'$480',  stock:'Ilimitado',  status:'Activo',  sales:48 },
  { id:2,  code:'PRD-002',  name:'CRM Professional',           cat:'Software',    price:'$1,200',  cost:'$240',  stock:'Ilimitado',  status:'Activo',  sales:124 },
  { id:3,  code:'PRD-003',  name:'CRM Starter',                cat:'Software',    price:'$480',    cost:'$96',   stock:'Ilimitado',  status:'Activo',  sales:312 },
  { id:4,  code:'PRD-004',  name:'Módulo Marketing Avanzado',  cat:'Add-on',      price:'$600',    cost:'$120',  stock:'Ilimitado',  status:'Activo',  sales:67 },
  { id:5,  code:'PRD-005',  name:'Módulo Soporte Premium',     cat:'Add-on',      price:'$480',    cost:'$96',   stock:'Ilimitado',  status:'Activo',  sales:43 },
  { id:6,  code:'PRD-006',  name:'Implementación Básica',      cat:'Servicio',    price:'$1,800',  cost:'$900',  stock:'—',          status:'Activo',  sales:28 },
  { id:7,  code:'PRD-007',  name:'Implementación Enterprise',  cat:'Servicio',    price:'$8,500',  cost:'$3,400',stock:'—',          status:'Activo',  sales:12 },
  { id:8,  code:'PRD-008',  name:'Soporte Anual Básico',       cat:'Servicio',    price:'$960',    cost:'$300',  stock:'—',          status:'Activo',  sales:86 },
  { id:9,  code:'PRD-009',  name:'Capacitación (10h)',         cat:'Capacitación',price:'$1,200',  cost:'$400',  stock:'—',          status:'Activo',  sales:34 },
  { id:10, code:'PRD-010',  name:'API Premium (12 meses)',     cat:'Add-on',      price:'$2,400',  cost:'$480',  stock:'Ilimitado',  status:'Beta',    sales:8  },
];
---
<CRMLayout title="Productos">

  <div class="page-header">
    <div>
      <h1 class="page-title">Catálogo de Productos</h1>
      <p class="page-subtitle">Gestión de productos, servicios y precios</p>
    </div>
    <div class="gap-actions">
      <button class="btn btn-secondary btn-sm" onclick="openModal('modal-lista-precios')">📋 Lista de precios</button>
      <button class="btn btn-primary btn-sm" onclick="openModal('modal-producto')">+ Nuevo Producto</button>
    </div>
  </div>

  <div class="kpi-grid" style="grid-template-columns:repeat(4,1fr);">
    <div class="kpi-card kpi-blue">
      <div class="kpi-value">32</div><div class="kpi-label">Productos activos</div>
    </div>
    <div class="kpi-card kpi-green">
      <div class="kpi-value">$1,240,800</div><div class="kpi-label">Ingresos totales (año)</div>
      <div class="kpi-change up">↑ 22%</div>
    </div>
    <div class="kpi-card kpi-gold">
      <div class="kpi-value">762</div><div class="kpi-label">Ventas este año</div>
    </div>
    <div class="kpi-card kpi-orange">
      <div class="kpi-value">68%</div><div class="kpi-label">Margen promedio</div>
      <div class="kpi-change up">↑ 2%</div>
    </div>
  </div>

  <div class="toolbar">
    <div class="search-input-wrap">
      <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
      </svg>
      <input class="search-input" placeholder="Buscar producto o servicio…">
    </div>
    <select class="form-control" style="width:auto;padding:0.47rem 0.75rem;">
      <option>Todas las categorías</option>
      <option>Software</option><option>Add-on</option><option>Servicio</option><option>Capacitación</option>
    </select>
    <select class="form-control" style="width:auto;padding:0.47rem 0.75rem;">
      <option>Todos los estados</option>
      <option>Activo</option><option>Beta</option><option>Descontinuado</option>
    </select>
    <div class="spacer"></div>
  </div>

  <div class="card">
    <div style="overflow-x:auto;">
      <table class="data-table">
        <thead>
          <tr>
            <th>Código</th>
            <th>Producto / Servicio</th>
            <th>Categoría</th>
            <th>Precio</th>
            <th>Costo</th>
            <th>Margen</th>
            <th>Disponibilidad</th>
            <th>Estado</th>
            <th>Ventas</th>
            <th>Acciones</th>
          </tr>
        </thead>
        <tbody>
          {products.map(p => {
            const priceNum = parseFloat(p.price.replace(/[$,]/g,''));
            const costNum  = parseFloat(p.cost.replace(/[$,]/g,''));
            const margin   = Math.round((1 - costNum/priceNum)*100);
            return (
              <tr>
                <td style="font-size:0.7rem;color:var(--text-muted);font-family:monospace;">{p.code}</td>
                <td>
                  <div style="display:flex;align-items:center;gap:0.5rem;">
                    <div style="width:30px;height:30px;background:#e8f0f9;border-radius:6px;display:flex;align-items:center;justify-content:center;font-size:0.75rem;">📦</div>
                    <span class="font-semibold">{p.name}</span>
                  </div>
                </td>
                <td><span class="badge badge-navy">{p.cat}</span></td>
                <td class="font-semibold">{p.price}</td>
                <td class="text-muted">{p.cost}</td>
                <td>
                  <span style={`font-weight:600;color:${margin>=60?'var(--success)':margin>=40?'var(--warning)':'var(--danger)'}`}>{margin}%</span>
                </td>
                <td class="text-muted text-xs">{p.stock}</td>
                <td>
                  <span class={`badge ${p.status==='Activo'?'badge-green':p.status==='Beta'?'badge-blue':'badge-gray'}`}>{p.status}</span>
                </td>
                <td class="font-semibold">{p.sales}</td>
                <td>
                  <div class="gap-actions">
                    <button class="btn btn-ghost btn-sm btn-icon" title="Editar" onclick="openModal('modal-editar-producto')">✏️</button>
                    <button class="btn btn-ghost btn-sm btn-icon" title="Ver detalle" onclick="openModal('modal-ver-producto')">📋</button>
                    <button class="btn btn-ghost btn-sm btn-icon" title="Más" onclick="openModal('modal-acciones-producto')">⋯</button>
                  </div>
                </td>
              </tr>
            );
          })}
        </tbody>
      </table>
    </div>
    <div style="padding:0.875rem 1.25rem;border-top:1px solid var(--border);">
      <span class="text-muted text-xs">Mostrando 1-10 de 32 productos</span>
    </div>
  </div>

<!-- Modal: Ver Producto -->
<div class="modal-overlay" id="modal-ver-producto">
  <div class="modal" style="max-width:560px;">
    <div class="modal-header">
      <div class="modal-title">📋 Detalle del Producto</div>
      <button class="modal-close" onclick="closeModal('modal-ver-producto')">✕</button>
    </div>
    <div class="modal-body">
      <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:1rem;">
        <div>
          <div style="font-size:1rem;font-weight:700;">Módulo HR Empresarial</div>
          <div style="font-size:0.78rem;color:var(--text-muted);">SKU: MOD-HR-ENT · Categoría: Software</div>
        </div>
        <span class="badge badge-green">Activo</span>
      </div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:0.75rem;margin-bottom:1rem;">
        <div style="background:#f8fafc;border-radius:0.4rem;padding:0.7rem;">
          <div style="font-size:0.7rem;color:var(--text-muted);margin-bottom:0.2rem;">Precio de venta</div>
          <div style="font-size:1.1rem;font-weight:700;color:var(--primary);">$12,600</div>
        </div>
        <div style="background:#f8fafc;border-radius:0.4rem;padding:0.7rem;">
          <div style="font-size:0.7rem;color:var(--text-muted);margin-bottom:0.2rem;">Costo</div>
          <div style="font-size:1.1rem;font-weight:700;">$4,800</div>
        </div>
        <div style="background:#f0fdf4;border-radius:0.4rem;padding:0.7rem;">
          <div style="font-size:0.7rem;color:var(--text-muted);margin-bottom:0.2rem;">Margen</div>
          <div style="font-size:1.1rem;font-weight:700;color:var(--success);">62%</div>
        </div>
        <div style="background:#f8fafc;border-radius:0.4rem;padding:0.7rem;">
          <div style="font-size:0.7rem;color:var(--text-muted);margin-bottom:0.2rem;">Ventas totales</div>
          <div style="font-size:1.1rem;font-weight:700;">128</div>
        </div>
      </div>
      <div style="font-size:0.8rem;">
        <div style="font-weight:600;margin-bottom:0.3rem;">Descripción</div>
        <div style="color:var(--text-muted);line-height:1.6;">Módulo completo de gestión de recursos humanos con nómina, asistencia, vacaciones y evaluaciones de desempeño. Incluye soporte premium y actualizaciones anuales.</div>
      </div>
    </div>
    <div class="modal-footer">
      <button class="btn btn-secondary btn-sm" onclick="closeModal('modal-ver-producto')">Cerrar</button>
      <button class="btn btn-primary btn-sm" onclick="closeModal('modal-ver-producto');openModal('modal-editar-producto')">✏️ Editar producto</button>
    </div>
  </div>
</div>

<!-- Modal: Editar Producto -->
<div class="modal-overlay" id="modal-editar-producto">
  <div class="modal">
    <div class="modal-header">
      <div class="modal-title">✏️ Editar Producto</div>
      <button class="modal-close" onclick="closeModal('modal-editar-producto')">✕</button>
    </div>
    <div class="modal-body">
      <div class="form-row">
        <div class="form-group">
          <label>Nombre del producto</label>
          <input class="form-control" value="Módulo HR Empresarial">
        </div>
        <div class="form-group">
          <label>SKU</label>
          <input class="form-control" value="MOD-HR-ENT">
        </div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label>Precio de venta</label>
          <input class="form-control" type="number" value="12600">
        </div>
        <div class="form-group">
          <label>Costo</label>
          <input class="form-control" type="number" value="4800">
        </div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label>Categoría</label>
          <select class="form-control">
            <option selected>Software</option>
            <option>Hardware</option>
            <option>Servicio</option>
            <option>Suscripción</option>
          </select>
        </div>
        <div class="form-group">
          <label>Estado</label>
          <select class="form-control">
            <option selected>Activo</option>
            <option>Beta</option>
            <option>Descontinuado</option>
          </select>
        </div>
      </div>
      <div class="form-group">
        <label>Descripción</label>
        <textarea class="form-control" style="min-height:80px;">Módulo completo de gestión de recursos humanos con nómina, asistencia, vacaciones y evaluaciones de desempeño.</textarea>
      </div>
    </div>
    <div class="modal-footer">
      <button class="btn btn-secondary btn-sm" onclick="closeModal('modal-editar-producto')">Cancelar</button>
      <button class="btn btn-primary btn-sm">💾 Guardar cambios</button>
    </div>
  </div>
</div>

<!-- Modal: Acciones Producto -->
<div class="modal-overlay" id="modal-acciones-producto">
  <div class="modal" style="max-width:360px;">
    <div class="modal-header">
      <div class="modal-title">⋯ Acciones de Producto</div>
      <button class="modal-close" onclick="closeModal('modal-acciones-producto')">✕</button>
    </div>
    <div class="modal-body" style="padding:0.5rem 0;gap:0;">
      <button class="menu-action-btn" onclick="closeModal('modal-acciones-producto');openModal('modal-ver-producto')">📋 Ver detalle</button>
      <button class="menu-action-btn" onclick="closeModal('modal-acciones-producto');openModal('modal-editar-producto')">✏️ Editar producto</button>
      <button class="menu-action-btn">🔄 Duplicar producto</button>
      <button class="menu-action-btn">💰 Actualizar precios</button>
      <div style="border-top:1px solid var(--border);margin:0.4rem 0;"></div>
      <button class="menu-action-btn" style="color:var(--danger);">🗑 Eliminar producto</button>
    </div>
  </div>
</div>

<!-- Modal: Editar Lista de Precios -->
<div class="modal-overlay" id="modal-editar-lista-precios">
  <div class="modal" style="max-width:620px;">
    <div class="modal-header">
      <div class="modal-title">✏️ Editar Lista de Precios</div>
      <button class="modal-close" onclick="closeModal('modal-editar-lista-precios')">✕</button>
    </div>
    <div class="modal-body">
      <div class="form-row" style="margin-bottom:0.5rem;">
        <div class="form-group">
          <label>Nombre de la lista</label>
          <input class="form-control" value="Lista Estándar 2026">
        </div>
        <div class="form-group">
          <label>Moneda</label>
          <select class="form-control">
            <option selected>USD ($)</option>
            <option>MXN ($)</option>
            <option>EUR (€)</option>
          </select>
        </div>
      </div>
      <div style="font-size:0.75rem;font-weight:600;color:var(--text-muted);text-transform:uppercase;margin-bottom:0.4rem;">Precios por producto</div>
      <div style="display:flex;flex-direction:column;gap:0.5rem;">
        {[['Módulo HR Empresarial','12600'],['CRM Pro','8400'],['Soporte Premium','2400'],['Implementación','5000']].map(([name, price]) => (
          <div style="display:flex;align-items:center;gap:0.75rem;padding:0.5rem;border:1px solid var(--border);border-radius:0.4rem;">
            <span style="flex:1;font-size:0.8rem;font-weight:500;">{name}</span>
            <input class="form-control" type="number" value={price} style="width:130px;">
          </div>
        ))}
      </div>
    </div>
    <div class="modal-footer">
      <button class="btn btn-secondary btn-sm" onclick="closeModal('modal-editar-lista-precios')">Cancelar</button>
      <button class="btn btn-primary btn-sm">💾 Guardar lista</button>
    </div>
  </div>
</div>

<!-- Modal: Lista de Precios -->
<div class="modal-overlay" id="modal-lista-precios">
  <div class="modal" style="max-width:680px;">
    <div class="modal-header">
      <div class="modal-title">📋 Lista de Precios — Vigente 2026</div>
      <button class="modal-close" onclick="closeModal('modal-lista-precios')">✕</button>
    </div>
    <div class="modal-body">
      <div style="display:flex;gap:0.5rem;margin-bottom:0.75rem;">
        <button class="btn btn-primary btn-sm">Estándar</button>
        <button class="btn btn-ghost btn-sm">Mayoreo</button>
        <button class="btn btn-ghost btn-sm">Gobierno</button>
        <button class="btn btn-ghost btn-sm">Partners</button>
      </div>
      <table style="width:100%;border-collapse:collapse;font-size:0.8rem;">
        <thead><tr style="background:#f8fafc;">
          <th style="padding:0.5rem;text-align:left;">Producto</th>
          <th style="padding:0.5rem;text-align:right;">Precio base</th>
          <th style="padding:0.5rem;text-align:right;">Descuento</th>
          <th style="padding:0.5rem;text-align:right;">Precio final</th>
        </tr></thead>
        <tbody>
          {[['Módulo HR Empresarial','$12,600','0%','$12,600'],['CRM Pro','$8,400','0%','$8,400'],['Soporte Premium','$2,400','0%','$2,400'],['Implementación','$5,000','0%','$5,000']].map(([name,base,disc,final]) => (
            <tr style="border-top:1px solid var(--border);">
              <td style="padding:0.5rem;">{name}</td>
              <td style="padding:0.5rem;text-align:right;">{base}</td>
              <td style="padding:0.5rem;text-align:right;">{disc}</td>
              <td style="padding:0.5rem;text-align:right;font-weight:600;color:var(--primary);">{final}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
    <div class="modal-footer">
      <button class="btn btn-secondary btn-sm" onclick="closeModal('modal-lista-precios')">Cerrar</button>
      <button class="btn btn-secondary btn-sm" onclick="closeModal('modal-lista-precios');openModal('modal-editar-lista-precios')">✏️ Editar lista</button>
      <button class="btn btn-primary btn-sm">⬇️ Exportar PDF</button>
    </div>
  </div>
</div>

<!-- Modal: Nuevo Producto -->
<div class="modal-overlay" id="modal-producto">
  <div class="modal">
    <div class="modal-header">
      <div class="modal-title">📦 Nuevo Producto</div>
      <button class="modal-close" onclick="closeModal('modal-producto')">✕</button>
    </div>
    <div class="modal-body">
      <div class="form-row">
        <div class="form-group">
          <label>Nombre del producto</label>
          <input class="form-control" type="text" placeholder="Ej: CRM Pro License">
        </div>
        <div class="form-group">
          <label>Código SKU</label>
          <input class="form-control" type="text" placeholder="Ej: CRM-PRO-001">
        </div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label>Categoría</label>
          <select class="form-control">
            <option>Software</option>
            <option>Hardware</option>
            <option>Servicio</option>
            <option>Licencia</option>
            <option>Soporte</option>
          </select>
        </div>
        <div class="form-group">
          <label>Estado</label>
          <select class="form-control">
            <option>Activo</option>
            <option>Inactivo</option>
            <option>En desarrollo</option>
          </select>
        </div>
      </div>
      <div class="form-row-3">
        <div class="form-group">
          <label>Precio de venta ($)</label>
          <input class="form-control" type="text" placeholder="$0.00">
        </div>
        <div class="form-group">
          <label>Costo ($)</label>
          <input class="form-control" type="text" placeholder="$0.00">
        </div>
        <div class="form-group">
          <label>Stock</label>
          <input class="form-control" type="number" placeholder="0">
        </div>
      </div>
      <div class="form-group">
        <label>Descripción</label>
        <textarea class="form-control" placeholder="Descripción detallada del producto…"></textarea>
      </div>
    </div>
    <div class="modal-footer">
      <button class="btn btn-secondary btn-sm" onclick="closeModal('modal-producto')">Cancelar</button>
      <button class="btn btn-primary btn-sm">Guardar Producto</button>
    </div>
  </div>
</div>

</CRMLayout>
