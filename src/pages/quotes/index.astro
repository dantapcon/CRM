---
import CRMLayout from '../../layouts/CRMLayout.astro';

const quotes = [
  { id:'COT-2026-042', client:'Tecno S.A.',        contact:'Carlos Ruiz',     date:'01 Mar 2026', valid:'31 Mar 2026', amount:'$28,500', status:'Enviada',   prob:75 },
  { id:'COT-2026-041', client:'Global Corp',        contact:'Ana López',       date:'28 Feb 2026', valid:'30 Mar 2026', amount:'$22,000', status:'En revisión',prob:60 },
  { id:'COT-2026-040', client:'NetSol Ltda.',       contact:'Mario Torres',    date:'25 Feb 2026', valid:'27 Mar 2026', amount:'$18,000', status:'Borrador',   prob:35 },
  { id:'COT-2026-039', client:'InnoTech',           contact:'Felipe Castro',   date:'22 Feb 2026', valid:'24 Mar 2026', amount:'$12,600', status:'Aceptada',   prob:100 },
  { id:'COT-2026-038', client:'MegaTrade',          contact:'Pedro Mendoza',   date:'18 Feb 2026', valid:'20 Mar 2026', amount:'$42,000', status:'Negociación',prob:80 },
  { id:'COT-2026-037', client:'FinGroup',           contact:'Andrés Silva',    date:'15 Feb 2026', valid:'17 Mar 2026', amount:'$30,800', status:'Enviada',    prob:65 },
  { id:'COT-2026-036', client:'Retail Max',         contact:'Carolina Morales',date:'10 Feb 2026', valid:'12 Mar 2026', amount:'$22,000', status:'Aceptada',   prob:100 },
  { id:'COT-2026-035', client:'DataPoint S.A.',     contact:'Lucía Herrera',   date:'05 Feb 2026', valid:'07 Mar 2026', amount:'$14,000', status:'Rechazada',  prob:0   },
];
const stMap: Record<string,string> = {
  'Borrador':'badge-gray','Enviada':'badge-blue','En revisión':'badge-yellow',
  'Negociación':'badge-orange','Aceptada':'badge-green','Rechazada':'badge-red'
};
---
<CRMLayout title="Cotizaciones">

  <div class="page-header">
    <div>
      <h1 class="page-title">Cotizaciones</h1>
      <p class="page-subtitle">Propuestas comerciales y presupuestos enviados a clientes</p>
    </div>
    <div class="gap-actions">
      <button class="btn btn-primary btn-sm" onclick="openModal('modal-cotizacion')">+ Nueva Cotización</button>
    </div>
  </div>

  <div class="kpi-grid" style="grid-template-columns:repeat(4,1fr);">
    <div class="kpi-card kpi-blue">
      <div class="kpi-value">28</div><div class="kpi-label">Cotizaciones activas</div>
    </div>
    <div class="kpi-card kpi-gold">
      <div class="kpi-value">$248,500</div><div class="kpi-label">Valor total pipeline</div>
      <div class="kpi-change up">↑ 8.3%</div>
    </div>
    <div class="kpi-card kpi-green">
      <div class="kpi-value">68%</div><div class="kpi-label">Tasa de aceptación</div>
      <div class="kpi-change up">↑ 4%</div>
    </div>
    <div class="kpi-card kpi-orange">
      <div class="kpi-value">6.2d</div><div class="kpi-label">Tiempo de respuesta</div>
      <div class="kpi-change up">↓ 1.1d</div>
    </div>
  </div>

  <div class="toolbar">
    <div class="search-input-wrap">
      <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
      </svg>
      <input class="search-input" placeholder="Buscar cotización…">
    </div>
    <select class="form-control" style="width:auto;padding:0.47rem 0.75rem;">
      <option>Todos los estados</option>
      <option>Borrador</option><option>Enviada</option><option>En revisión</option>
      <option>Negociación</option><option>Aceptada</option><option>Rechazada</option>
    </select>
    <div class="spacer"></div>
  </div>

  <div class="card">
    <div style="overflow-x:auto;">
      <table class="data-table">
        <thead>
          <tr>
            <th>Número</th>
            <th>Cliente</th>
            <th>Contacto</th>
            <th>Fecha</th>
            <th>Vence</th>
            <th>Monto</th>
            <th>Estado</th>
            <th>Probabilidad</th>
            <th>Acciones</th>
          </tr>
        </thead>
        <tbody>
          {quotes.map(q => (
            <tr>
              <td style="font-family:monospace;font-size:0.72rem;font-weight:600;color:var(--primary);">{q.id}</td>
              <td class="font-semibold">{q.client}</td>
              <td class="text-muted text-xs">{q.contact}</td>
              <td class="text-xs text-muted">{q.date}</td>
              <td class="text-xs text-muted">{q.valid}</td>
              <td class="font-semibold" style="color:var(--success);">{q.amount}</td>
              <td><span class={`badge ${stMap[q.status]}`}>{q.status}</span></td>
              <td>
                <div style="display:flex;align-items:center;gap:0.4rem;">
                  <div class="progress-bar" style="width:60px;">
                    <div class="progress-fill" style={`width:${q.prob}%;background:${q.prob>=80?'var(--success)':q.prob>=50?'var(--warning)':'var(--danger)'}`}></div>
                  </div>
                  <span style="font-size:0.72rem;font-weight:600;">{q.prob}%</span>
                </div>
              </td>
              <td>
                <div class="gap-actions">
                  <button class="btn btn-ghost btn-sm btn-icon" title="Ver PDF" onclick="openModal('modal-pdf-cotizacion')">📄</button>
                  <button class="btn btn-ghost btn-sm btn-icon" title="Enviar" onclick="openModal('modal-enviar-cotizacion')">📤</button>
                  <button class="btn btn-ghost btn-sm btn-icon" title="Editar" onclick="openModal('modal-editar-cotizacion')">✏️</button>
                  <button class="btn btn-ghost btn-sm btn-icon" title="Más" onclick="openModal('modal-acciones-cotizacion')">⋯</button>
                </div>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
    <div style="padding:0.875rem 1.25rem;border-top:1px solid var(--border);">
      <span class="text-muted text-xs">Mostrando 1-8 de 28 cotizaciones</span>
    </div>
  </div>

<!-- Modal: Ver PDF Cotización -->
<div class="modal-overlay" id="modal-pdf-cotizacion">
  <div class="modal" style="max-width:700px;">
    <div class="modal-header">
      <div class="modal-title">📄 Vista Previa — Cotización</div>
      <button class="modal-close" onclick="closeModal('modal-pdf-cotizacion')">✕</button>
    </div>
    <div class="modal-body">
      <div style="background:#f8fafc;border:1px solid var(--border);border-radius:0.5rem;padding:1.5rem;">
        <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:1.5rem;">
          <div>
            <div style="font-size:1.3rem;font-weight:700;color:var(--primary);">NexusCRM</div>
            <div style="font-size:0.75rem;color:var(--text-muted);">www.nexuscrm.com · info@nexuscrm.com</div>
          </div>
          <div style="text-align:right;">
            <div style="font-size:1rem;font-weight:700;">COTIZACIÓN</div>
            <div style="font-size:0.82rem;color:var(--primary);font-weight:600;">COT-2026-042</div>
            <div style="font-size:0.72rem;color:var(--text-muted);">Fecha: 01 Mar 2026</div>
            <div style="font-size:0.72rem;color:var(--text-muted);">Válida hasta: 31 Mar 2026</div>
          </div>
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-bottom:1.5rem;">
          <div><div style="font-size:0.7rem;font-weight:600;text-transform:uppercase;color:var(--text-muted);margin-bottom:0.3rem;">Cliente</div>
            <div style="font-weight:600;">Tecno S.A.</div><div style="font-size:0.78rem;color:var(--text-muted);">Carlos Ruiz — Director Comercial</div></div>
          <div><div style="font-size:0.7rem;font-weight:600;text-transform:uppercase;color:var(--text-muted);margin-bottom:0.3rem;">Vendedor</div>
            <div style="font-weight:600;">María Pérez</div><div style="font-size:0.78rem;color:var(--text-muted);">mperez@nexuscrm.com</div></div>
        </div>
        <table style="width:100%;border-collapse:collapse;font-size:0.8rem;margin-bottom:1rem;">
          <thead><tr style="background:#e8f0f9;">
            <th style="padding:0.5rem 0.75rem;text-align:left;">Producto / Servicio</th>
            <th style="padding:0.5rem 0.75rem;text-align:right;">Cant.</th>
            <th style="padding:0.5rem 0.75rem;text-align:right;">Precio unit.</th>
            <th style="padding:0.5rem 0.75rem;text-align:right;">Subtotal</th>
          </tr></thead>
          <tbody>
            <tr style="border-bottom:1px solid var(--border);"><td style="padding:0.5rem 0.75rem;">CRM Enterprise Suite</td><td style="padding:0.5rem 0.75rem;text-align:right;">10</td><td style="padding:0.5rem 0.75rem;text-align:right;">$2,400</td><td style="padding:0.5rem 0.75rem;text-align:right;font-weight:600;">$24,000</td></tr>
            <tr style="border-bottom:1px solid var(--border);"><td style="padding:0.5rem 0.75rem;">Implementación Enterprise</td><td style="padding:0.5rem 0.75rem;text-align:right;">1</td><td style="padding:0.5rem 0.75rem;text-align:right;">$4,500</td><td style="padding:0.5rem 0.75rem;text-align:right;font-weight:600;">$4,500</td></tr>
          </tbody>
          <tfoot><tr style="background:#f1f5f9;"><td colspan="3" style="padding:0.5rem 0.75rem;font-weight:700;text-align:right;">TOTAL</td><td style="padding:0.5rem 0.75rem;font-weight:700;text-align:right;color:var(--success);font-size:0.95rem;">$28,500</td></tr></tfoot>
        </table>
      </div>
    </div>
    <div class="modal-footer">
      <button class="btn btn-secondary btn-sm" onclick="closeModal('modal-pdf-cotizacion')">Cerrar</button>
      <button class="btn btn-secondary btn-sm">📤 Enviar al cliente</button>
      <button class="btn btn-primary btn-sm">⬇️ Descargar PDF</button>
    </div>
  </div>
</div>

<!-- Modal: Enviar Cotización -->
<div class="modal-overlay" id="modal-enviar-cotizacion">
  <div class="modal">
    <div class="modal-header">
      <div class="modal-title">📤 Enviar Cotización al Cliente</div>
      <button class="modal-close" onclick="closeModal('modal-enviar-cotizacion')">✕</button>
    </div>
    <div class="modal-body">
      <div class="form-group">
        <label>Para (email del cliente)</label>
        <input class="form-control" type="email" value="c.ruiz@tecno.com">
      </div>
      <div class="form-group">
        <label>CC</label>
        <input class="form-control" type="email" placeholder="copia@empresa.com (opcional)">
      </div>
      <div class="form-group">
        <label>Asunto</label>
        <input class="form-control" value="Cotización COT-2026-042 — NexusCRM">
      </div>
      <div class="form-group">
        <label>Mensaje</label>
        <textarea class="form-control" style="min-height:120px;">Estimado Carlos,

Adjunto encontrará nuestra cotización COT-2026-042 por $28,500 con validez hasta el 31 de marzo.

Quedamos atentos a cualquier pregunta.

Saludos,
María Pérez</textarea>
      </div>
      <div style="display:flex;align-items:center;gap:0.5rem;font-size:0.8rem;color:var(--text-muted);">
        <span>📎</span><span>COT-2026-042.pdf adjunto automáticamente</span>
      </div>
    </div>
    <div class="modal-footer">
      <button class="btn btn-secondary btn-sm" onclick="closeModal('modal-enviar-cotizacion')">Cancelar</button>
      <button class="btn btn-primary btn-sm">📤 Enviar Cotización</button>
    </div>
  </div>
</div>

<!-- Modal: Editar Cotización -->
<div class="modal-overlay" id="modal-editar-cotizacion">
  <div class="modal">
    <div class="modal-header">
      <div class="modal-title">✏️ Editar Cotización</div>
      <button class="modal-close" onclick="closeModal('modal-editar-cotizacion')">✕</button>
    </div>
    <div class="modal-body">
      <div class="form-row">
        <div class="form-group">
          <label>Cliente / Contacto</label>
          <input class="form-control" value="Carlos Ruiz">
        </div>
        <div class="form-group">
          <label>Cuenta / Empresa</label>
          <input class="form-control" value="Tecno S.A.">
        </div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label>Estado</label>
          <select class="form-control">
            <option>Borrador</option><option selected>Enviada</option><option>En revisión</option><option>Negociación</option><option>Aceptada</option><option>Rechazada</option>
          </select>
        </div>
        <div class="form-group">
          <label>Validez (días)</label>
          <input class="form-control" type="number" value="30">
        </div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label>Moneda</label>
          <select class="form-control"><option>COP</option><option selected>USD</option></select>
        </div>
        <div class="form-group">
          <label>Descuento global (%)</label>
          <input class="form-control" type="number" value="0">
        </div>
      </div>
      <div class="form-group">
        <label>Notas / Términos</label>
        <textarea class="form-control" placeholder="Términos, condiciones o notas para el cliente…"></textarea>
      </div>
    </div>
    <div class="modal-footer">
      <button class="btn btn-secondary btn-sm" onclick="closeModal('modal-editar-cotizacion')">Cancelar</button>
      <button class="btn btn-primary btn-sm">💾 Guardar Cambios</button>
    </div>
  </div>
</div>

<!-- Modal: Acciones Cotización -->
<div class="modal-overlay" id="modal-acciones-cotizacion">
  <div class="modal" style="max-width:360px;">
    <div class="modal-header">
      <div class="modal-title">⋯ Acciones de Cotización</div>
      <button class="modal-close" onclick="closeModal('modal-acciones-cotizacion')">✕</button>
    </div>
    <div class="modal-body" style="padding:0.5rem 0;gap:0;">
      <button class="menu-action-btn" onclick="closeModal('modal-acciones-cotizacion');openModal('modal-pdf-cotizacion')">📄 Ver PDF</button>
      <button class="menu-action-btn" onclick="closeModal('modal-acciones-cotizacion');openModal('modal-enviar-cotizacion')">📤 Enviar al cliente</button>
      <button class="menu-action-btn" onclick="closeModal('modal-acciones-cotizacion');openModal('modal-editar-cotizacion')">✏️ Editar cotización</button>
      <button class="menu-action-btn">🖿️ Duplicar cotización</button>
      <button class="menu-action-btn">🧧 Convertir a factura</button>
      <div style="border-top:1px solid var(--border);margin:0.4rem 0;"></div>
      <button class="menu-action-btn" style="color:var(--danger);" onclick="closeModal('modal-acciones-cotizacion');openModal('modal-confirm-eliminar')">🗑 Eliminar cotización</button>
    </div>
  </div>
</div>

<!-- Modal: Nueva Cotización -->
<div class="modal-overlay" id="modal-cotizacion">
  <div class="modal">
    <div class="modal-header">
      <div class="modal-title">📋 Nueva Cotización</div>
      <button class="modal-close" onclick="closeModal('modal-cotizacion')">✕</button>
    </div>
    <div class="modal-body">
      <div class="form-row">
        <div class="form-group">
          <label>Cliente / Contacto</label>
          <input class="form-control" type="text" placeholder="Nombre del cliente">
        </div>
        <div class="form-group">
          <label>Cuenta / Empresa</label>
          <input class="form-control" type="text" placeholder="Empresa">
        </div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label>Oportunidad relacionada</label>
          <input class="form-control" type="text" placeholder="Buscar oportunidad…">
        </div>
        <div class="form-group">
          <label>Validez (días)</label>
          <input class="form-control" type="number" placeholder="30">
        </div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label>Moneda</label>
          <select class="form-control">
            <option>COP - Peso Colombiano</option>
            <option>USD - Dólar</option>
            <option>EUR - Euro</option>
          </select>
        </div>
        <div class="form-group">
          <label>Descuento global (%)</label>
          <input class="form-control" type="number" min="0" max="100" placeholder="0">
        </div>
      </div>
      <div class="form-group">
        <label>Notas / Términos</label>
        <textarea class="form-control" placeholder="Términos, condiciones o notas para el cliente…"></textarea>
      </div>
    </div>
    <div class="modal-footer">
      <button class="btn btn-secondary btn-sm" onclick="closeModal('modal-cotizacion')">Cancelar</button>
      <button class="btn btn-primary btn-sm">Crear Cotización</button>
    </div>
  </div>
</div>

</CRMLayout>
