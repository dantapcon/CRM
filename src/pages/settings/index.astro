---
import CRMLayout from '../../layouts/CRMLayout.astro';
---
<CRMLayout title="Configuración">

  <div class="page-header">
    <div>
      <h1 class="page-title">Configuración del Sistema</h1>
      <p class="page-subtitle">Ajustes generales, integraciones y personalización de Maki</p>
    </div>
    <div class="gap-actions">
      <button class="btn btn-primary btn-sm" onclick="openModal('modal-guardar-configuracion')">💾 Guardar cambios</button>
    </div>
  </div>

  <div class="grid-21">
    <!-- Left sidebar nav -->
    <div style="display:flex;flex-direction:column;gap:1.25rem;">

      <!-- Settings left nav -->
      <div class="card">
        <div style="padding:0.5rem 0;">
          {[
            { icon:'🏢', label:'General',            id:'general',        active:true },
            { icon:'👤', label:'Mi perfil',           id:'perfil' },
            { icon:'🔒', label:'Seguridad',           id:'seguridad' },
            { icon:'👥', label:'Usuarios y roles',    id:'usuarios' },
            { icon:'🔔', label:'Notificaciones',      id:'notificaciones' },
            { icon:'🎨', label:'Personalización',     id:'personalizacion' },
            { icon:'🗄️', label:'Datos y campos',      id:'datos' },
            { icon:'🔌', label:'Integraciones',       id:'integraciones' },
            { icon:'📧', label:'Email y plantillas',  id:'email' },
            { icon:'📊', label:'Reportes',             id:'reportes' },
            { icon:'💳', label:'Facturación y plan',  id:'facturacion' },
            { icon:'🛡️', label:'Privacidad y GDPR',   id:'privacidad' },
            { icon:'📋', label:'Auditoría y logs',    id:'auditoria' },
            { icon:'🔧', label:'API y webhooks',      id:'api' },
          ].map(s => (
            <div onclick={`openModal('modal-settings-${s.id}')`} style={`display:flex;align-items:center;gap:0.6rem;padding:0.55rem 1.25rem;cursor:pointer;background:${s.active?'rgba(37,99,168,0.1)':'transparent'};border-right:${s.active?'3px solid var(--primary)':'3px solid transparent'};`}>
              <span>{s.icon}</span>
              <span style={`font-size:0.8rem;font-weight:${s.active?'600':'400'};color:${s.active?'var(--primary)':'var(--text)'}`}>{s.label}</span>
            </div>
          ))}
        </div>
      </div>

    </div>

    <!-- Right content -->
    <div style="display:flex;flex-direction:column;gap:1.25rem;">

      <!-- General settings -->
      <div class="card">
        <div class="card-header">
          <h3 class="card-title">🏢 Configuración General</h3>
        </div>
        <div class="card-body">
          <div class="form-row form-row-2">
            <div class="form-group">
              <label class="form-label">Nombre de la empresa</label>
              <input class="form-control" value="Mi Empresa S.A.">
            </div>
            <div class="form-group">
              <label class="form-label">NIT / RUT</label>
              <input class="form-control" value="900.123.456-7">
            </div>
            <div class="form-group">
              <label class="form-label">Email principal</label>
              <input class="form-control" type="email" value="info@miempresa.com">
            </div>
            <div class="form-group">
              <label class="form-label">Teléfono</label>
              <input class="form-control" value="+57 1 234 5678">
            </div>
            <div class="form-group">
              <label class="form-label">Sitio web</label>
              <input class="form-control" value="https://miempresa.com">
            </div>
            <div class="form-group">
              <label class="form-label">País</label>
              <select class="form-control">
                <option selected>Colombia</option>
                <option>México</option><option>Argentina</option><option>Chile</option>
              </select>
            </div>
            <div class="form-group">
              <label class="form-label">Zona horaria</label>
              <select class="form-control">
                <option selected>América/Bogotá (UTC-5)</option>
                <option>América/México_City (UTC-6)</option>
              </select>
            </div>
            <div class="form-group">
              <label class="form-label">Moneda predeterminada</label>
              <select class="form-control">
                <option selected>COP — Peso Colombiano</option>
                <option>USD — Dólar Americano</option>
                <option>EUR — Euro</option>
                <option>MXN — Peso Mexicano</option>
              </select>
            </div>
          </div>
          <div class="form-group">
            <label class="form-label">Dirección</label>
            <input class="form-control" value="Calle 72 No. 12-45, Bogotá, Colombia">
          </div>
        </div>
      </div>

      <!-- Pipeline stages -->
      <div class="card">
        <div class="card-header">
          <h3 class="card-title">🔄 Etapas del Pipeline de Ventas</h3>
          <button class="btn btn-secondary btn-sm" onclick="openModal('modal-etapa-pipeline')">+ Agregar etapa</button>
        </div>
        <div class="card-body" style="padding:0;">
          {[
            { name:'Prospección',    prob:20, color:'#0284c7', order:1 },
            { name:'Calificación',   prob:35, color:'#7c3aed', order:2 },
            { name:'Propuesta',      prob:55, color:'#c8a558', order:3 },
            { name:'Negociación',    prob:75, color:'#d97706', order:4 },
            { name:'Ganado',         prob:100,color:'#16a34a', order:5 },
          ].map(s => (
            <div style="display:flex;align-items:center;gap:1rem;padding:0.75rem 1.25rem;border-bottom:1px solid #f1f5f9;">
              <div style={`width:12px;height:12px;border-radius:50%;background:${s.color};flex-shrink:0;`}></div>
              <span style="min-width:120px;font-weight:500;font-size:0.8rem;">{s.name}</span>
              <input class="form-control" style="width:100px;" value={`${s.prob}%`} placeholder="Probabilidad">
              <input type="color" value={s.color} style="width:36px;height:30px;border:1px solid var(--border);border-radius:4px;cursor:pointer;padding:2px;">
              <div class="spacer"></div>
              <button class="btn btn-ghost btn-sm btn-icon" onclick="openModal('modal-etapa-pipeline')">↑</button>
              <button class="btn btn-ghost btn-sm btn-icon" onclick="openModal('modal-etapa-pipeline')">↓</button>
              <button class="btn btn-ghost btn-sm btn-icon" onclick="openModal('modal-editar-etapa')">✏️</button>
              <button class="btn btn-ghost btn-sm btn-icon" style="color:var(--danger);" onclick="openModal('modal-eliminar-etapa')">🗑</button>
            </div>
          ))}
        </div>
      </div>

      <!-- Notifications -->
      <div class="card">
        <div class="card-header">
          <h3 class="card-title">🔔 Notificaciones</h3>
        </div>
        <div class="card-body">
          {[
            { label:'Nuevo lead asignado',              email:true,  app:true  },
            { label:'Recordatorio de actividad',        email:true,  app:true  },
            { label:'Oportunidad sin actividad (7d)',   email:true,  app:false },
            { label:'Ticket crítico creado',            email:true,  app:true  },
            { label:'Cotización aceptada',              email:true,  app:true  },
            { label:'Factura vencida',                  email:true,  app:true  },
            { label:'Reporte semanal de ventas',        email:true,  app:false },
            { label:'Meta de ventas alcanzada',         email:false, app:true  },
          ].map(n => (
            <div style="display:flex;align-items:center;gap:1rem;padding:0.6rem 0;border-bottom:1px solid #f1f5f9;">
              <span style="flex:1;font-size:0.8rem;">{n.label}</span>
              <label style="display:flex;align-items:center;gap:0.4rem;font-size:0.72rem;">
                <input type="checkbox" checked={n.email}> Email
              </label>
              <label style="display:flex;align-items:center;gap:0.4rem;font-size:0.72rem;">
                <input type="checkbox" checked={n.app}> App
              </label>
            </div>
          ))}
        </div>
      </div>

      <!-- Integrations -->
      <div class="card">
        <div class="card-header">
          <h3 class="card-title">🔌 Integraciones</h3>
        </div>
        <div class="card-body">
          <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:0.75rem;">
            {[
              { name:'Google Workspace', icon:'📧', connected:true,   desc:'Email, Calendar, Drive'        },
              { name:'Slack',            icon:'💬', connected:true,   desc:'Notificaciones de equipo'      },
              { name:'WhatsApp Business',icon:'📱', connected:false,  desc:'Mensajería a clientes'         },
              { name:'Zapier',           icon:'⚡', connected:false,  desc:'Automatizaciones sin código'   },
              { name:'Stripe',           icon:'💳', connected:false,  desc:'Pagos y facturación'           },
              { name:'HubSpot',          icon:'🔶', connected:false,  desc:'Migración de datos'            },
              { name:'Mailchimp',        icon:'🐵', connected:true,   desc:'Email marketing'               },
              { name:'LinkedIn',         icon:'💼', connected:true,   desc:'Lead generation'               },
            ].map(int => (
              <div style="border:1px solid var(--border);border-radius:0.5rem;padding:0.875rem;display:flex;align-items:center;gap:0.75rem;">
                <div style="font-size:1.5rem;">{int.icon}</div>
                <div style="flex:1;">
                  <div style="font-size:0.82rem;font-weight:600;">{int.name}</div>
                  <div style="font-size:0.68rem;color:var(--text-muted);">{int.desc}</div>
                </div>
                {int.connected
                  ? <button class="btn btn-secondary btn-sm" onclick="openModal('modal-configurar-integracion')">Configurar</button>
                  : <button class="btn btn-primary btn-sm" onclick="openModal('modal-configurar-integracion')">Conectar</button>
                }
              </div>
            ))}
          </div>
        </div>
      </div>

    </div>
  </div>

<!-- Modal: Agregar / Editar Etapa Pipeline -->
<div class="modal-overlay" id="modal-etapa-pipeline">
  <div class="modal" style="max-width:440px;">
    <div class="modal-header">
      <div class="modal-title">🔄 Agregar Etapa al Pipeline</div>
      <button class="modal-close" onclick="closeModal('modal-etapa-pipeline')">✕</button>
    </div>
    <div class="modal-body">
      <div class="form-group">
        <label>Nombre de la etapa</label>
        <input class="form-control" placeholder="Ej: Demo programada">
      </div>
      <div class="form-row">
        <div class="form-group">
          <label>Probabilidad de cierre (%)</label>
          <input class="form-control" type="number" min="0" max="100" placeholder="50">
        </div>
        <div class="form-group">
          <label>Color</label>
          <input type="color" class="form-control" value="#188185" style="height:38px;padding:2px 4px;cursor:pointer;">
        </div>
      </div>
      <div class="form-group">
        <label>Posición en el pipeline</label>
        <select class="form-control">
          <option>Al final</option>
          <option>Después de Calificación</option>
          <option>Después de Propuesta</option>
          <option>Después de Negociación</option>
        </select>
      </div>
    </div>
    <div class="modal-footer">
      <button class="btn btn-secondary btn-sm" onclick="closeModal('modal-etapa-pipeline')">Cancelar</button>
      <button class="btn btn-primary btn-sm">+ Agregar etapa</button>
    </div>
  </div>
</div>

<!-- Modal: Editar Etapa Pipeline -->
<div class="modal-overlay" id="modal-editar-etapa">
  <div class="modal" style="max-width:440px;">
    <div class="modal-header">
      <div class="modal-title">✏️ Editar Etapa — Propuesta</div>
      <button class="modal-close" onclick="closeModal('modal-editar-etapa')">✕</button>
    </div>
    <div class="modal-body">
      <div class="form-group">
        <label>Nombre de la etapa</label>
        <input class="form-control" value="Propuesta">
      </div>
      <div class="form-row">
        <div class="form-group">
          <label>Probabilidad (%)</label>
          <input class="form-control" type="number" value="55">
        </div>
        <div class="form-group">
          <label>Color</label>
          <input type="color" class="form-control" value="#c8a558" style="height:38px;padding:2px 4px;cursor:pointer;">
        </div>
      </div>
    </div>
    <div class="modal-footer">
      <button class="btn btn-secondary btn-sm" onclick="closeModal('modal-editar-etapa')">Cancelar</button>
      <button class="btn btn-primary btn-sm">💾 Guardar cambios</button>
    </div>
  </div>
</div>

<!-- Modal: Eliminar Etapa Pipeline -->
<div class="modal-overlay" id="modal-eliminar-etapa">
  <div class="modal" style="max-width:400px;">
    <div class="modal-header">
      <div class="modal-title">🗑 Eliminar Etapa</div>
      <button class="modal-close" onclick="closeModal('modal-eliminar-etapa')">✕</button>
    </div>
    <div class="modal-body">
      <div style="text-align:center;padding:0.5rem 0;">
        <div style="font-size:2.5rem;margin-bottom:0.75rem;">⚠️</div>
        <div style="font-weight:600;margin-bottom:0.5rem;">¿Eliminar la etapa "Propuesta"?</div>
        <div style="font-size:0.82rem;color:var(--text-muted);">Las oportunidades en esta etapa serán movidas a la etapa anterior. Esta acción no se puede deshacer.</div>
      </div>
    </div>
    <div class="modal-footer">
      <button class="btn btn-secondary btn-sm" onclick="closeModal('modal-eliminar-etapa')">Cancelar</button>
      <button class="btn btn-danger btn-sm" style="background:var(--danger);color:#fff;border-color:var(--danger);">🗑 Eliminar etapa</button>
    </div>
  </div>
</div>

<!-- Modal: Configurar Integración -->
<div class="modal-overlay" id="modal-configurar-integracion">
  <div class="modal">
    <div class="modal-header">
      <div class="modal-title">🔌 Configurar Integración</div>
      <button class="modal-close" onclick="closeModal('modal-configurar-integracion')">✕</button>
    </div>
    <div class="modal-body">
      <div style="display:flex;align-items:center;gap:0.75rem;background:#f8fafc;border:1px solid var(--border);border-radius:0.4rem;padding:0.75rem;margin-bottom:1rem;">
        <span style="font-size:2rem;">📧</span>
        <div>
          <div style="font-weight:600;">Google Workspace</div>
          <div style="font-size:0.75rem;color:var(--text-muted);">Email, Calendar, Drive</div>
        </div>
        <span class="badge badge-green" style="margin-left:auto;">Conectado</span>
      </div>
      <div class="form-group">
        <label>Cuenta de Google conectada</label>
        <input class="form-control" value="admin@nexuscrm.com" readonly>
      </div>
      <div class="form-group">
        <label>Sincronizar</label>
        <div style="display:flex;flex-direction:column;gap:0.4rem;">
          <label style="display:flex;align-items:center;gap:0.5rem;font-size:0.8rem;cursor:pointer;"><input type="checkbox" checked> Gmail (registrar emails en CRM)</label>
          <label style="display:flex;align-items:center;gap:0.5rem;font-size:0.8rem;cursor:pointer;"><input type="checkbox" checked> Google Calendar (sincronizar eventos)</label>
          <label style="display:flex;align-items:center;gap:0.5rem;font-size:0.8rem;cursor:pointer;"><input type="checkbox"> Google Drive (adjuntar documentos)</label>
        </div>
      </div>
      <div class="form-group">
        <label>Dirección de webhook (opcional)</label>
        <input class="form-control" placeholder="https://tu-servidor.com/webhook">
      </div>
    </div>
    <div class="modal-footer">
      <button class="btn btn-secondary btn-sm" onclick="closeModal('modal-configurar-integracion')" style="color:var(--danger);">🔌 Desconectar</button>
      <button class="btn btn-secondary btn-sm" onclick="closeModal('modal-configurar-integracion')">Cancelar</button>
      <button class="btn btn-primary btn-sm">💾 Guardar configuración</button>
    </div>
  </div>
</div>

<!-- Modal: Confirmación Guardar Configuración -->
<div class="modal-overlay" id="modal-guardar-configuracion">
  <div class="modal" style="max-width:400px;">
    <div class="modal-header">
      <div class="modal-title">💾 Guardar Configuración</div>
      <button class="modal-close" onclick="closeModal('modal-guardar-configuracion')">✕</button>
    </div>
    <div class="modal-body">
      <div style="text-align:center;padding:0.5rem 0;">
        <div style="font-size:2.5rem;margin-bottom:0.75rem;">💾</div>
        <div style="font-weight:600;margin-bottom:0.5rem;">¿Guardar todos los cambios?</div>
        <div style="font-size:0.82rem;color:var(--text-muted);">Los cambios en perfil, pipeline, notificaciones e integraciones se aplicarán inmediatamente.</div>
      </div>
    </div>
    <div class="modal-footer">
      <button class="btn btn-secondary btn-sm" onclick="closeModal('modal-guardar-configuracion')">Cancelar</button>
      <button class="btn btn-primary btn-sm" onclick="closeModal('modal-guardar-configuracion')">💾 Confirmar y guardar</button>
    </div>
  </div>
</div>

<!-- Modal: Configuración General -->
<div class="modal-overlay" id="modal-settings-general">
  <div class="modal">
    <div class="modal-header">
      <div class="modal-title">🏢 Configuración General</div>
      <button class="modal-close" onclick="closeModal('modal-settings-general')">✕</button>
    </div>
    <div class="modal-body">
      <div class="form-row form-row-2">
        <div class="form-group">
          <label class="form-label">Nombre de la empresa</label>
          <input class="form-control" value="Mi Empresa S.A.">
        </div>
        <div class="form-group">
          <label class="form-label">NIT / RUT</label>
          <input class="form-control" value="900.123.456-7">
        </div>
        <div class="form-group">
          <label class="form-label">Email principal</label>
          <input class="form-control" type="email" value="info@miempresa.com">
        </div>
        <div class="form-group">
          <label class="form-label">País</label>
          <select class="form-control"><option selected>Colombia</option><option>México</option><option>Argentina</option></select>
        </div>
        <div class="form-group">
          <label class="form-label">Zona horaria</label>
          <select class="form-control"><option selected>América/Bogotá (UTC-5)</option></select>
        </div>
        <div class="form-group">
          <label class="form-label">Moneda</label>
          <select class="form-control"><option selected>COP — Peso Colombiano</option><option>USD — Dólar Americano</option></select>
        </div>
      </div>
    </div>
    <div class="modal-footer">
      <button class="btn btn-secondary btn-sm" onclick="closeModal('modal-settings-general')">Cancelar</button>
      <button class="btn btn-primary btn-sm">💾 Guardar</button>
    </div>
  </div>
</div>

<!-- Modal: Mi Perfil -->
<div class="modal-overlay" id="modal-settings-perfil">
  <div class="modal" style="max-width:480px;">
    <div class="modal-header">
      <div class="modal-title">👤 Mi Perfil</div>
      <button class="modal-close" onclick="closeModal('modal-settings-perfil')">✕</button>
    </div>
    <div class="modal-body">
      <div style="display:flex;align-items:center;gap:1rem;margin-bottom:1.25rem;padding-bottom:1.25rem;border-bottom:1px solid var(--border);">
        <div class="avatar" style="width:56px;height:56px;font-size:1.2rem;background:#188185;color:#fff;font-weight:700;flex-shrink:0;">JM</div>
        <div>
          <div style="font-weight:600;">Juan Martínez</div>
          <div style="font-size:0.75rem;color:var(--text-muted);">Administrador</div>
          <button class="btn btn-secondary btn-sm" style="margin-top:0.4rem;">📷 Cambiar foto</button>
        </div>
      </div>
      <div class="form-row form-row-2">
        <div class="form-group"><label class="form-label">Nombre</label><input class="form-control" value="Juan"></div>
        <div class="form-group"><label class="form-label">Apellido</label><input class="form-control" value="Martínez"></div>
        <div class="form-group"><label class="form-label">Email</label><input class="form-control" type="email" value="juan@miempresa.com"></div>
        <div class="form-group"><label class="form-label">Teléfono</label><input class="form-control" value="+57 310 000 0000"></div>
      </div>
      <div class="form-group">
        <label class="form-label">Biografía / firma</label>
        <textarea class="form-control" rows="2" placeholder="Añade una breve descripción..."></textarea>
      </div>
    </div>
    <div class="modal-footer">
      <button class="btn btn-secondary btn-sm" onclick="closeModal('modal-settings-perfil')">Cancelar</button>
      <button class="btn btn-primary btn-sm">💾 Guardar perfil</button>
    </div>
  </div>
</div>

<!-- Modal: Seguridad -->
<div class="modal-overlay" id="modal-settings-seguridad">
  <div class="modal" style="max-width:440px;">
    <div class="modal-header">
      <div class="modal-title">🔒 Seguridad</div>
      <button class="modal-close" onclick="closeModal('modal-settings-seguridad')">✕</button>
    </div>
    <div class="modal-body">
      <div class="form-group">
        <label class="form-label">Contraseña actual</label>
        <input class="form-control" type="password" placeholder="••••••••">
      </div>
      <div class="form-row form-row-2">
        <div class="form-group">
          <label class="form-label">Nueva contraseña</label>
          <input class="form-control" type="password" placeholder="••••••••">
        </div>
        <div class="form-group">
          <label class="form-label">Confirmar contraseña</label>
          <input class="form-control" type="password" placeholder="••••••••">
        </div>
      </div>
      <div style="padding:0.75rem;background:#f8fafc;border-radius:0.4rem;margin:0.5rem 0;">
        <div style="font-size:0.82rem;font-weight:600;margin-bottom:0.5rem;">Autenticación de dos factores (2FA)</div>
        <div style="display:flex;align-items:center;justify-content:space-between;">
          <span style="font-size:0.78rem;color:var(--text-muted);">Estado: Desactivado</span>
          <button class="btn btn-secondary btn-sm">Activar 2FA</button>
        </div>
      </div>
      <div style="padding:0.75rem;background:#fff7ed;border-radius:0.4rem;font-size:0.78rem;color:#92400e;">
        ⚠️ La sesiones activas en otros dispositivos serán cerradas al cambiar la contraseña.
      </div>
    </div>
    <div class="modal-footer">
      <button class="btn btn-secondary btn-sm" onclick="closeModal('modal-settings-seguridad')">Cancelar</button>
      <button class="btn btn-primary btn-sm">🔒 Actualizar contraseña</button>
    </div>
  </div>
</div>

<!-- Modal: Usuarios y Roles -->
<div class="modal-overlay" id="modal-settings-usuarios">
  <div class="modal">
    <div class="modal-header">
      <div class="modal-title">👥 Usuarios y Roles</div>
      <button class="modal-close" onclick="closeModal('modal-settings-usuarios')">✕</button>
    </div>
    <div class="modal-body">
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:1rem;">
        <span style="font-size:0.82rem;color:var(--text-muted);">4 usuarios activos</span>
        <button class="btn btn-primary btn-sm">+ Invitar usuario</button>
      </div>
      {[
