---
import CRMLayout from '../../layouts/CRMLayout.astro';

const invoices = [
  { id:'FAC-2026-088', client:'InnoTech',       date:'01 Mar 2026', due:'31 Mar 2026', amount:'$12,600', paid:'$12,600', status:'Pagada',    method:'Transferencia' },
  { id:'FAC-2026-087', client:'Retail Max',     date:'28 Feb 2026', due:'30 Mar 2026', amount:'$22,000', paid:'$0',      status:'Pendiente', method:'—'             },
  { id:'FAC-2026-086', client:'Tecno S.A.',     date:'25 Feb 2026', due:'27 Mar 2026', amount:'$4,800',  paid:'$4,800',  status:'Pagada',    method:'Tarjeta'       },
  { id:'FAC-2026-085', client:'Global Corp',    date:'22 Feb 2026', due:'24 Mar 2026', amount:'$8,400',  paid:'$4,200',  status:'Parcial',   method:'Transferencia' },
  { id:'FAC-2026-084', client:'FinGroup',       date:'18 Feb 2026', due:'20 Mar 2026', amount:'$15,200', paid:'$0',      status:'Vencida',   method:'—'             },
  { id:'FAC-2026-083', client:'MegaTrade',      date:'14 Feb 2026', due:'16 Mar 2026', amount:'$9,800',  paid:'$9,800',  status:'Pagada',    method:'Cheque'        },
  { id:'FAC-2026-082', client:'NetSol Ltda.',   date:'10 Feb 2026', due:'12 Mar 2026', amount:'$6,400',  paid:'$0',      status:'Vencida',   method:'—'             },
  { id:'FAC-2026-081', client:'DataPoint S.A.', date:'05 Feb 2026', due:'07 Mar 2026', amount:'$3,200',  paid:'$3,200',  status:'Pagada',    method:'Transferencia' },
];
const stMap: Record<string,string> = {
  'Pagada':'badge-green','Pendiente':'badge-blue','Parcial':'badge-yellow','Vencida':'badge-red'
};
---
<CRMLayout title="Facturas">

  <div class="page-header">
    <div>
      <h1 class="page-title">Facturas</h1>
      <p class="page-subtitle">Facturación, cobranza y control de pagos</p>
    </div>
    <div class="gap-actions">
      <button class="btn btn-secondary btn-sm" onclick="openModal('modal-reporte-cobros')">📊 Reporte cobros</button>
      <button class="btn btn-primary btn-sm" onclick="openModal('modal-factura')">+ Nueva Factura</button>
    </div>
  </div>

  <div class="kpi-grid" style="grid-template-columns:repeat(4,1fr);">
    <div class="kpi-card kpi-blue">
      <div class="kpi-value">$82,300</div><div class="kpi-label">Facturado (mes)</div>
      <div class="kpi-change up">↑ 21.4%</div>
    </div>
    <div class="kpi-card kpi-green">
      <div class="kpi-value">$56,900</div><div class="kpi-label">Cobrado (mes)</div>
      <div class="kpi-change up">↑ 15.2%</div>
    </div>
    <div class="kpi-card kpi-red">
      <div class="kpi-value">$25,400</div><div class="kpi-label">Por cobrar</div>
      <div class="kpi-change down">↑ $5,200 vencido</div>
    </div>
    <div class="kpi-card kpi-orange">
      <div class="kpi-value">18.3d</div><div class="kpi-label">DSO promedio</div>
      <div class="kpi-change up">↓ 2.4d</div>
    </div>
  </div>

  <div class="toolbar">
    <div class="search-input-wrap">
      <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
      </svg>
      <input class="search-input" placeholder="Buscar factura…">
    </div>
    <select class="form-control" style="width:auto;padding:0.47rem 0.75rem;">
      <option>Todos los estados</option>
      <option>Pagada</option><option>Pendiente</option><option>Parcial</option><option>Vencida</option>
    </select>
    <div class="spacer"></div>
  </div>

  <div class="card">
    <div style="overflow-x:auto;">
      <table class="data-table">
        <thead>
          <tr>
            <th>Número</th>
            <th>Cliente</th>
            <th>Fecha emisión</th>
            <th>Vencimiento</th>
            <th>Monto</th>
            <th>Pagado</th>
            <th>Pendiente</th>
            <th>Estado</th>
            <th>Método de pago</th>
            <th>Acciones</th>
          </tr>
        </thead>
        <tbody>
          {invoices.map(inv => {
            const total = parseFloat(inv.amount.replace(/[$,]/g,''));
            const pagado = parseFloat(inv.paid.replace(/[$,]/g,'') || '0');
            const pendiente = total - pagado;
            return (
              <tr>
                <td style="font-family:monospace;font-size:0.72rem;font-weight:600;color:var(--primary);">{inv.id}</td>
                <td class="font-semibold">{inv.client}</td>
                <td class="text-xs text-muted">{inv.date}</td>
                <td class="text-xs text-muted">{inv.due}</td>
                <td class="font-semibold">{inv.amount}</td>
                <td style="color:var(--success);font-weight:500;">{inv.paid}</td>
                <td style={`font-weight:500;color:${pendiente>0?'var(--danger)':'var(--text-muted)'}`}>
                  {pendiente > 0 ? `$${pendiente.toLocaleString()}` : '—'}
                </td>
                <td><span class={`badge ${stMap[inv.status]}`}>{inv.status}</span></td>
                <td class="text-xs text-muted">{inv.method}</td>
                <td>
                  <div class="gap-actions">
                    <button class="btn btn-ghost btn-sm btn-icon" title="Ver PDF" onclick="openModal('modal-pdf-factura')">📄</button>
                    <button class="btn btn-ghost btn-sm btn-icon" title="Enviar" onclick="openModal('modal-enviar-factura')">📤</button>
                    <button class="btn btn-ghost btn-sm btn-icon" title="Más" onclick="openModal('modal-acciones-factura')">⋯</button>
                  </div>
                </td>
              </tr>
            );
          })}
        </tbody>
      </table>
    </div>
    <div style="padding:0.875rem 1.25rem;border-top:1px solid var(--border);">
      <span class="text-muted text-xs">Mostrando 1-8 de 88 facturas</span>
    </div>
  </div>

<!-- Modal: Reporte Cobros -->
<div class="modal-overlay" id="modal-reporte-cobros">
  <div class="modal" style="max-width:620px;">
    <div class="modal-header">
      <div class="modal-title">📊 Reporte de Cobros</div>
      <button class="modal-close" onclick="closeModal('modal-reporte-cobros')">✕</button>
    </div>
    <div class="modal-body">
      <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:0.75rem;margin-bottom:1rem;">
        <div style="background:#f0fdf4;border-radius:0.5rem;padding:0.75rem;text-align:center;border:1px solid #bbf7d0;">
          <div style="font-size:1.2rem;font-weight:700;color:var(--success);">$148,200</div>
          <div style="font-size:0.72rem;color:var(--text-muted);">Cobrado este mes</div>
        </div>
        <div style="background:#fff7ed;border-radius:0.5rem;padding:0.75rem;text-align:center;border:1px solid #fed7aa;">
          <div style="font-size:1.2rem;font-weight:700;color:var(--warning);">$32,400</div>
          <div style="font-size:0.72rem;color:var(--text-muted);">Pendiente de cobro</div>
        </div>
        <div style="background:#fef2f2;border-radius:0.5rem;padding:0.75rem;text-align:center;border:1px solid #fecaca;">
          <div style="font-size:1.2rem;font-weight:700;color:var(--danger);">$8,600</div>
          <div style="font-size:0.72rem;color:var(--text-muted);">Vencido</div>
        </div>
      </div>
      <table style="width:100%;border-collapse:collapse;font-size:0.8rem;">
        <thead><tr style="background:#f8fafc;">
          <th style="padding:0.5rem;text-align:left;">Cliente</th>
          <th style="padding:0.5rem;text-align:right;">Monto</th>
          <th style="padding:0.5rem;text-align:left;">Vencimiento</th>
          <th style="padding:0.5rem;text-align:center;">Estado</th>
        </tr></thead>
        <tbody>
          {[['InnoTech','$12,600','31 Mar 2026','Pagada','badge-green'],['GlobalRetail','$28,900','15 Abr 2026','Pendiente','badge-orange'],['MegaCorp','$8,600','01 Mar 2026','Vencida','badge-red']].map(([client,amount,due,status,badge]) => (
            <tr style="border-top:1px solid var(--border);">
              <td style="padding:0.5rem;font-weight:500;">{client}</td>
              <td style="padding:0.5rem;text-align:right;font-weight:600;">{amount}</td>
              <td style="padding:0.5rem;">{due}</td>
              <td style="padding:0.5rem;text-align:center;"><span class={`badge ${badge}`}>{status}</span></td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
    <div class="modal-footer">
      <button class="btn btn-secondary btn-sm" onclick="closeModal('modal-reporte-cobros')">Cerrar</button>
      <button class="btn btn-primary btn-sm">⬇️ Exportar PDF</button>
    </div>
  </div>
</div>

<!-- Modal: Ver PDF Factura -->
<div class="modal-overlay" id="modal-pdf-factura">
  <div class="modal" style="max-width:700px;">
    <div class="modal-header">
      <div class="modal-title">🧧 Vista Previa — Factura</div>
      <button class="modal-close" onclick="closeModal('modal-pdf-factura')">✕</button>
    </div>
    <div class="modal-body">
      <div style="background:#f8fafc;border:1px solid var(--border);border-radius:0.5rem;padding:1.5rem;">
        <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:1.5rem;">
          <div>
            <div style="font-size:1.3rem;font-weight:700;color:var(--primary);">NexusCRM</div>
            <div style="font-size:0.75rem;color:var(--text-muted);">www.nexuscrm.com · info@nexuscrm.com</div>
          </div>
          <div style="text-align:right;">
            <div style="font-size:1rem;font-weight:700;">FACTURA</div>
            <div style="font-size:0.82rem;color:var(--primary);font-weight:600;">FAC-2026-088</div>
            <div style="font-size:0.72rem;color:var(--text-muted);">Emisión: 01 Mar 2026</div>
            <div style="font-size:0.72rem;color:var(--danger);font-weight:600;">Vence: 31 Mar 2026</div>
          </div>
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-bottom:1.5rem;">
          <div>
            <div style="font-size:0.7rem;font-weight:600;text-transform:uppercase;color:var(--text-muted);margin-bottom:0.3rem;">Facturado a</div>
            <div style="font-weight:600;">InnoTech</div>
            <div style="font-size:0.78rem;color:var(--text-muted);">Felipe Castro — Gerente Financiero</div>
          </div>
          <div>
            <div style="font-size:0.7rem;font-weight:600;text-transform:uppercase;color:var(--text-muted);margin-bottom:0.3rem;">Estado de pago</div>
            <span class="badge badge-green" style="font-size:0.8rem;padding:4px 12px;">PAGADA</span>
          </div>
        </div>
        <table style="width:100%;border-collapse:collapse;font-size:0.8rem;margin-bottom:1rem;">
          <thead><tr style="background:#e8f0f9;">
            <th style="padding:0.5rem 0.75rem;text-align:left;">Descripción</th>
            <th style="padding:0.5rem 0.75rem;text-align:right;">Cant.</th>
            <th style="padding:0.5rem 0.75rem;text-align:right;">Precio unit.</th>
            <th style="padding:0.5rem 0.75rem;text-align:right;">Total</th>
          </tr></thead>
          <tbody>
            <tr style="border-bottom:1px solid var(--border);"><td style="padding:0.5rem 0.75rem;">Módulo HR — InnoTech</td><td style="padding:0.5rem 0.75rem;text-align:right;">1</td><td style="padding:0.5rem 0.75rem;text-align:right;">$12,600</td><td style="padding:0.5rem 0.75rem;text-align:right;font-weight:600;">$12,600</td></tr>
          </tbody>
          <tfoot><tr style="background:#f1f5f9;"><td colspan="3" style="padding:0.5rem 0.75rem;font-weight:700;text-align:right;">TOTAL</td><td style="padding:0.5rem 0.75rem;font-weight:700;text-align:right;color:var(--success);font-size:0.95rem;">$12,600</td></tr></tfoot>
        </table>
        <div style="font-size:0.75rem;color:var(--text-muted);">Método de pago: Transferencia bancaria · Pagado el 15 Mar 2026</div>
      </div>
    </div>
    <div class="modal-footer">
      <button class="btn btn-secondary btn-sm" onclick="closeModal('modal-pdf-factura')">Cerrar</button>
      <button class="btn btn-secondary btn-sm" onclick="closeModal('modal-pdf-factura');openModal('modal-enviar-factura')">📤 Reenviar al cliente</button>
      <button class="btn btn-primary btn-sm">⬇️ Descargar PDF</button>
    </div>
  </div>
</div>

<!-- Modal: Enviar Factura -->
<div class="modal-overlay" id="modal-enviar-factura">
  <div class="modal">
    <div class="modal-header">
      <div class="modal-title">📤 Enviar Factura al Cliente</div>
      <button class="modal-close" onclick="closeModal('modal-enviar-factura')">✕</button>
    </div>
    <div class="modal-body">
      <div class="form-group">
        <label>Para (email del cliente)</label>
        <input class="form-control" type="email" value="fcastro@innotech.io">
      </div>
      <div class="form-group">
        <label>CC (contabilidad u otros)</label>
        <input class="form-control" type="email" placeholder="contabilidad@empresa.com (opcional)">
      </div>
      <div class="form-group">
        <label>Asunto</label>
        <input class="form-control" value="Factura FAC-2026-088 — NexusCRM">
      </div>
      <div class="form-group">
        <label>Mensaje</label>
        <textarea class="form-control" style="min-height:100px;">Estimado Felipe,

Adjunto la factura FAC-2026-088 por $12,600 con vencimiento el 31 de marzo de 2026.

Muchas gracias por su confianza.

Saludos,
NexusCRM</textarea>
      </div>
      <div style="display:flex;align-items:center;gap:0.5rem;font-size:0.8rem;color:var(--text-muted);">
        <span>📎</span><span>FAC-2026-088.pdf adjunto automáticamente</span>
      </div>
    </div>
    <div class="modal-footer">
      <button class="btn btn-secondary btn-sm" onclick="closeModal('modal-enviar-factura')">Cancelar</button>
      <button class="btn btn-primary btn-sm">📤 Enviar Factura</button>
    </div>
  </div>
</div>

<!-- Modal: Acciones Factura -->
<div class="modal-overlay" id="modal-acciones-factura">
  <div class="modal" style="max-width:360px;">
    <div class="modal-header">
      <div class="modal-title">⋯ Acciones de Factura</div>
      <button class="modal-close" onclick="closeModal('modal-acciones-factura')">✕</button>
    </div>
    <div class="modal-body" style="padding:0.5rem 0;gap:0;">
      <button class="menu-action-btn" onclick="closeModal('modal-acciones-factura');openModal('modal-pdf-factura')">📄 Ver / Descargar PDF</button>
      <button class="menu-action-btn" onclick="closeModal('modal-acciones-factura');openModal('modal-enviar-factura')">📤 Enviar al cliente</button>
      <button class="menu-action-btn">💳 Registrar pago</button>
      <button class="menu-action-btn">🗑️ Nota de crédito</button>
      <button class="menu-action-btn">🔄 Duplicar factura</button>
      <div style="border-top:1px solid var(--border);margin:0.4rem 0;"></div>
      <button class="menu-action-btn" style="color:var(--danger);" onclick="closeModal('modal-acciones-factura');openModal('modal-confirm-eliminar')">🗑 Anular factura</button>
    </div>
  </div>
</div>

<!-- Modal: Nueva Factura -->
<div class="modal-overlay" id="modal-factura">
  <div class="modal">
    <div class="modal-header">
      <div class="modal-title">🧾 Nueva Factura</div>
      <button class="modal-close" onclick="closeModal('modal-factura')">✕</button>
    </div>
    <div class="modal-body">
      <div class="form-row">
        <div class="form-group">
          <label>Cliente</label>
          <input class="form-control" type="text" placeholder="Nombre del cliente">
        </div>
        <div class="form-group">
          <label>Número de factura</label>
          <input class="form-control" type="text" placeholder="FAC-2026-0001">
        </div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label>Fecha de emisión</label>
          <input class="form-control" type="date">
        </div>
        <div class="form-group">
          <label>Fecha de vencimiento</label>
          <input class="form-control" type="date">
        </div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label>Moneda</label>
          <select class="form-control">
            <option>COP - Peso Colombiano</option>
            <option>USD - Dólar</option>
            <option>EUR - Euro</option>
          </select>
        </div>
        <div class="form-group">
          <label>Cotización origen</label>
          <input class="form-control" type="text" placeholder="COT-2026-0001 (opcional)">
        </div>
      </div>
      <div class="form-group">
        <label>Notas internas</label>
        <textarea class="form-control" placeholder="Notas o instrucciones de pago…"></textarea>
      </div>
    </div>
    <div class="modal-footer">
      <button class="btn btn-secondary btn-sm" onclick="closeModal('modal-factura')">Cancelar</button>
      <button class="btn btn-primary btn-sm">Emitir Factura</button>
    </div>
  </div>
</div>

</CRMLayout>
