---
import CRMLayout from '../../layouts/CRMLayout.astro';

const stages = [
  {
    name: 'Prospección', color: '#0284c7', count: 8, total: '$28,400',
    items: [
      { name:'Sistema ERP - Alpha IT',      company:'Alpha IT',       value:'$8,200',  days:5,  owner:'CV', prob:20 },
      { name:'CRM License - BetaTech',      company:'BetaTech',       value:'$6,500',  days:3,  owner:'MP', prob:20 },
      { name:'Consultoría - Gamma Corp',    company:'Gamma Corp',     value:'$4,800',  days:8,  owner:'LA', prob:15 },
    ],
  },
  {
    name: 'Calificación', color: '#7c3aed', count: 6, total: '$45,200',
    items: [
      { name:'Cloud Migration - NetSol',    company:'NetSol Ltda.',   value:'$18,000', days:12, owner:'AR', prob:35 },
      { name:'BI Dashboard - DataPoint',    company:'DataPoint S.A.', value:'$14,000', days:7,  owner:'PS', prob:40 },
      { name:'Integración API - Epsilon',   company:'Epsilon S.A.',   value:'$13,200', days:15, owner:'CV', prob:30 },
    ],
  },
  {
    name: 'Propuesta', color: '#c8a558', count: 5, total: '$63,100',
    items: [
      { name:'Software Suite - Tecno S.A.', company:'Tecno S.A.',     value:'$28,500', days:18, owner:'MP', prob:55 },
      { name:'Soporte Anual - Global Corp', company:'Global Corp',    value:'$22,000', days:22, owner:'LA', prob:60 },
      { name:'Módulo HR - InnoTech',        company:'InnoTech',       value:'$12,600', days:9,  owner:'AR', prob:50 },
    ],
  },
  {
    name: 'Negociación', color: '#d97706', count: 4, total: '$72,800',
    items: [
      { name:'Enterprise Plan - MegaTrade', company:'MegaTrade',      value:'$42,000', days:25, owner:'CV', prob:75 },
      { name:'Licencias - FinGroup',        company:'FinGroup',       value:'$30,800', days:30, owner:'MP', prob:70 },
    ],
  },
  {
    name: 'Ganado ✓', color: '#16a34a', count: 3, total: '$39,000',
    items: [
      { name:'CRM Impl. - Retail Max',      company:'Retail Max',     value:'$22,000', days:45, owner:'LA', prob:100 },
      { name:'Mantenimiento - SoftCo',      company:'SoftCo',         value:'$17,000', days:40, owner:'AR', prob:100 },
    ],
  },
];
---
<CRMLayout title="Oportunidades">

  <div class="page-header">
    <div>
      <h1 class="page-title">Oportunidades</h1>
      <p class="page-subtitle">Pipeline de ventas y gestión de oportunidades activas</p>
    </div>
    <div class="gap-actions">
      <button class="btn btn-secondary btn-sm">⊞ Tablero</button>
      <button class="btn btn-secondary btn-sm">☰ Lista</button>
      <button class="btn btn-secondary btn-sm" onclick="openModal('modal-forecast')">📊 Forecast</button>
      <button class="btn btn-primary btn-sm" onclick="openModal('modal-oportunidad')">+ Nueva Oportunidad</button>
    </div>
  </div>

  <!-- KPIs -->
  <div class="kpi-grid" style="grid-template-columns:repeat(5,1fr);">
    <div class="kpi-card kpi-blue">
      <div class="kpi-value">26</div><div class="kpi-label">Oportunidades activas</div>
      <div class="kpi-change up">↑ 4 nuevas</div>
    </div>
    <div class="kpi-card kpi-gold">
      <div class="kpi-value">$248,500</div><div class="kpi-label">Valor del pipeline</div>
      <div class="kpi-change up">↑ 4.7%</div>
    </div>
    <div class="kpi-card kpi-green">
      <div class="kpi-value">$82,300</div><div class="kpi-label">Cerrado este mes</div>
      <div class="kpi-change up">↑ 21.4%</div>
    </div>
    <div class="kpi-card kpi-orange">
      <div class="kpi-value">22%</div><div class="kpi-label">Tasa de cierre</div>
      <div class="kpi-change up">↑ 2.1%</div>
    </div>
    <div class="kpi-card kpi-red">
      <div class="kpi-value">18d</div><div class="kpi-label">Ciclo prom. de venta</div>
      <div class="kpi-change up">↓ 3d más rápido</div>
    </div>
  </div>

  <!-- Filter bar -->
  <div class="toolbar">
    <div class="search-input-wrap">
      <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
      </svg>
      <input class="search-input" placeholder="Buscar oportunidad…">
    </div>
    <select class="form-control" style="width:auto;padding:0.47rem 0.75rem;">
      <option>Todos los responsables</option>
      <option>Carlos V.</option><option>María P.</option><option>Luis A.</option><option>Ana R.</option><option>Pedro S.</option>
    </select>
    <select class="form-control" style="width:auto;padding:0.47rem 0.75rem;">
      <option>Todos los períodos</option>
      <option>Este mes</option><option>Este trimestre</option><option>Este año</option>
    </select>
    <div class="spacer"></div>
    <span style="font-size:0.75rem;color:var(--success);font-weight:600;">Pipeline: $248,500</span>
  </div>

  <!-- Kanban Board -->
  <div class="pipeline-board">
    {stages.map(stage => (
      <div class="pipeline-col">
        <div class="pipeline-col-header" style={`border-top:3px solid ${stage.color}`}>
          <div>
            <div class="pipeline-col-title">{stage.name}</div>
            <div style="font-size:0.68rem;color:var(--text-muted);margin-top:1px;">{stage.total}</div>
          </div>
          <span class="badge badge-gray">{stage.count}</span>
        </div>
        <div class="pipeline-col-body">
          {stage.items.map(item => (
            <div class="pipeline-card" onclick="openModal('modal-ver-oportunidad')">
              <div class="pipeline-card-title">{item.name}</div>
              <div class="pipeline-card-company">🏢 {item.company}</div>
              <div class="pipeline-phase-bar">
                <div class="pipeline-phase-fill" style={`width:${item.prob}%;background:${stage.color}`}></div>
              </div>
              <div class="pipeline-card-footer">
                <span style="font-size:0.75rem;font-weight:700;color:var(--text);">{item.value}</span>
                <div style="display:flex;align-items:center;gap:0.3rem;">
                  <div class="avatar" style="width:20px;height:20px;font-size:0.55rem;background:var(--primary);">{item.owner}</div>
                  <span style="font-size:0.65rem;color:var(--text-muted);">{item.days}d</span>
                </div>
              </div>
              <div style="font-size:0.65rem;color:var(--text-muted);margin-top:0.3rem;">Prob: {item.prob}%</div>
            </div>
          ))}
          <button style="width:100%;padding:0.5rem;border:1px dashed var(--border);background:transparent;border-radius:0.375rem;font-size:0.72rem;color:var(--text-muted);cursor:pointer;" onclick="openModal('modal-oportunidad')">+ Agregar oportunidad</button>
        </div>
      </div>
    ))}
  </div>
<!-- Modal: Forecast -->
<div class="modal-overlay" id="modal-forecast">
  <div class="modal" style="max-width:640px;">
    <div class="modal-header">
      <div class="modal-title">📊 Forecast de Ventas — Q1 2026</div>
      <button class="modal-close" onclick="closeModal('modal-forecast')">✕</button>
    </div>
    <div class="modal-body">
      <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:0.75rem;margin-bottom:1rem;">
        <div style="background:#eff6ff;border-radius:0.5rem;padding:0.75rem;text-align:center;border:1px solid #bfdbfe;">
          <div style="font-size:1.1rem;font-weight:700;color:var(--info);">$620,000</div>
          <div style="font-size:0.72rem;color:var(--text-muted);">Pipeline total</div>
        </div>
        <div style="background:#f0fdf4;border-radius:0.5rem;padding:0.75rem;text-align:center;border:1px solid #bbf7d0;">
          <div style="font-size:1.1rem;font-weight:700;color:var(--success);">$248,000</div>
          <div style="font-size:0.72rem;color:var(--text-muted);">Forecast ajustado</div>
        </div>
        <div style="background:#f5f3ff;border-radius:0.5rem;padding:0.75rem;text-align:center;border:1px solid #ddd6fe;">
          <div style="font-size:1.1rem;font-weight:700;color:#7c3aed;">$350,000</div>
          <div style="font-size:0.72rem;color:var(--text-muted);">Meta del trimestre</div>
        </div>
      </div>
      <table style="width:100%;border-collapse:collapse;font-size:0.8rem;">
        <thead><tr style="background:#f8fafc;">
          <th style="padding:0.5rem;text-align:left;">Oportunidad</th>
          <th style="padding:0.5rem;text-align:right;">Valor</th>
          <th style="padding:0.5rem;text-align:center;">Prob.</th>
          <th style="padding:0.5rem;text-align:right;">Forecast</th>
        </tr></thead>
        <tbody>
          {[['ERP MegaCorp','$95,000','70%','$66,500'],['Módulo RRHH GlobalRetail','$75,000','55%','$41,250'],['CRM Cloud InnoTech','$48,000','85%','$40,800']].map(([name,val,prob,fore]) => (
            <tr style="border-top:1px solid var(--border);">
              <td style="padding:0.5rem;font-weight:500;">{name}</td>
              <td style="padding:0.5rem;text-align:right;">{val}</td>
              <td style="padding:0.5rem;text-align:center;"><span class="badge badge-blue">{prob}</span></td>
              <td style="padding:0.5rem;text-align:right;font-weight:600;color:var(--success);">{fore}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
    <div class="modal-footer">
      <button class="btn btn-secondary btn-sm" onclick="closeModal('modal-forecast')">Cerrar</button>
      <button class="btn btn-primary btn-sm">⬇️ Exportar forecast</button>
    </div>
  </div>
</div>

<!-- Modal: Editar Oportunidad -->
<div class="modal-overlay" id="modal-editar-oportunidad">
  <div class="modal">
    <div class="modal-header">
      <div class="modal-title">✏️ Editar Oportunidad</div>
      <button class="modal-close" onclick="closeModal('modal-editar-oportunidad')">✕</button>
    </div>
    <div class="modal-body">
      <div class="form-group">
        <label>Nombre de la oportunidad</label>
        <input class="form-control" value="ERP MegaCorp">
      </div>
      <div class="form-row">
        <div class="form-group">
          <label>Valor estimado</label>
          <input class="form-control" type="number" value="95000">
        </div>
        <div class="form-group">
          <label>Fecha cierre estimada</label>
          <input class="form-control" type="date" value="2026-04-15">
        </div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label>Etapa</label>
          <select class="form-control">
            <option>Prospección</option>
            <option>Calificación</option>
            <option selected>Propuesta</option>
            <option>Negociación</option>
            <option>Ganado</option>
          </select>
        </div>
        <div class="form-group">
          <label>Probabilidad (%)</label>
          <input class="form-control" type="number" value="70">
        </div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label>Cuenta</label>
          <select class="form-control">
            <option selected>MegaCorp</option>
            <option>InnoTech</option>
            <option>GlobalRetail</option>
          </select>
        </div>
        <div class="form-group">
          <label>Responsable</label>
          <select class="form-control">
            <option selected>Carlos López</option>
            <option>María López</option>
          </select>
        </div>
      </div>
    </div>
    <div class="modal-footer">
      <button class="btn btn-secondary btn-sm" onclick="closeModal('modal-editar-oportunidad')">Cancelar</button>
      <button class="btn btn-primary btn-sm">💾 Guardar cambios</button>
    </div>
  </div>
</div>

<!-- Modal: Ver Oportunidad -->
<div class="modal-overlay" id="modal-ver-oportunidad">
  <div class="modal" style="max-width:700px;">
    <div class="modal-header">
      <div class="modal-title">💼 Detalle de la Oportunidad</div>
      <button class="modal-close" onclick="closeModal('modal-ver-oportunidad')">✕</button>
    </div>
    <div class="modal-body">
      <div style="display:flex;align-items:center;gap:1rem;padding-bottom:1rem;border-bottom:1px solid var(--border);margin-bottom:1rem;">
        <div style="flex:1;">
          <div style="font-size:1.1rem;font-weight:700;">Software Suite — Tecno S.A.</div>
          <div style="font-size:0.8rem;color:var(--text-muted);margin-top:0.25rem;">🏢 Tecno S.A. · Responsable: María P.</div>
        </div>
        <span class="badge badge-gold" style="font-size:0.8rem;padding:4px 12px;">Propuesta</span>
      </div>
      <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:0.75rem;margin-bottom:1rem;">
        <div style="background:#f8fafc;border-radius:0.5rem;padding:0.875rem;text-align:center;">
          <div style="font-size:1.2rem;font-weight:700;color:var(--success);">$28,500</div>
          <div style="font-size:0.68rem;color:var(--text-muted);text-transform:uppercase;margin-top:2px;">Valor</div>
        </div>
        <div style="background:#f8fafc;border-radius:0.5rem;padding:0.875rem;text-align:center;">
          <div style="font-size:1.2rem;font-weight:700;color:var(--warning);">55%</div>
          <div style="font-size:0.68rem;color:var(--text-muted);text-transform:uppercase;margin-top:2px;">Probabilidad</div>
        </div>
        <div style="background:#f8fafc;border-radius:0.5rem;padding:0.875rem;text-align:center;">
          <div style="font-size:1.2rem;font-weight:700;">18d</div>
          <div style="font-size:0.68rem;color:var(--text-muted);text-transform:uppercase;margin-top:2px;">En pipeline</div>
        </div>
      </div>
      <div style="margin-bottom:1rem;">
        <div style="font-size:0.75rem;font-weight:600;color:var(--text-muted);text-transform:uppercase;margin-bottom:0.5rem;">Progreso del pipeline</div>
        <div style="display:flex;gap:4px;">
          {['Prospección','Calificación','Propuesta','Negociación','Ganado'].map((s, i) => (
            <div style={`flex:1;height:6px;border-radius:3px;background:${i<=2?'var(--primary)':'var(--border)'}`}></div>
          ))}
        </div>
        <div style="display:flex;justify-content:space-between;font-size:0.62rem;color:var(--text-muted);margin-top:4px;">
          <span>Prospección</span><span>Calificación</span><span style="font-weight:700;color:var(--primary);">Propuesta</span><span>Negociación</span><span>Ganado</span>
        </div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label>Mover a etapa</label>
          <select class="form-control">
            <option>Prospección</option><option>Calificación</option><option selected>Propuesta</option><option>Negociación</option><option>Ganado ✓</option>
          </select>
        </div>
        <div class="form-group">
          <label>Fecha cierre estimada</label>
          <input class="form-control" type="date">
        </div>
      </div>
      <div class="form-group">
        <label>Notas rápidas</label>
        <textarea class="form-control" placeholder="Agregar nota sobre esta oportunidad…"></textarea>
      </div>
    </div>
    <div class="modal-footer">
      <button class="btn btn-secondary btn-sm" onclick="closeModal('modal-ver-oportunidad')">Cerrar</button>
      <button class="btn btn-secondary btn-sm" onclick="closeModal('modal-ver-oportunidad');openModal('modal-editar-oportunidad')">✏️ Editar</button>
      <button class="btn btn-primary btn-sm" style="background:var(--success);border-color:var(--success);">🏆 Marcar como Ganada</button>
    </div>
  </div>
</div>

<!-- Modal: Nueva Oportunidad -->
<div class="modal-overlay" id="modal-oportunidad">
  <div class="modal">
    <div class="modal-header">
      <div class="modal-title">💼 Nueva Oportunidad</div>
      <button class="modal-close" onclick="closeModal('modal-oportunidad')">✕</button>
    </div>
    <div class="modal-body">
      <div class="form-group">
        <label>Nombre de la oportunidad</label>
        <input class="form-control" type="text" placeholder="Ej: Renovación contrato anual">
      </div>
      <div class="form-row">
        <div class="form-group">
          <label>Cuenta / Empresa</label>
          <input class="form-control" type="text" placeholder="Empresa">
        </div>
        <div class="form-group">
          <label>Contacto principal</label>
          <input class="form-control" type="text" placeholder="Nombre">
        </div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label>Valor ($)</label>
          <input class="form-control" type="text" placeholder="$0">
        </div>
        <div class="form-group">
          <label>Probabilidad (%)</label>
          <input class="form-control" type="number" min="0" max="100" placeholder="50">
        </div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label>Etapa</label>
          <select class="form-control">
            <option>Prospectando</option>
            <option>Calificado</option>
            <option>Propuesta enviada</option>
            <option>Negociación</option>
            <option>Cierre</option>
          </select>
        </div>
        <div class="form-group">
          <label>Fecha cierre estimada</label>
          <input class="form-control" type="date">
        </div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label>Responsable</label>
          <select class="form-control">
            <option>Carlos V.</option>
            <option>María P.</option>
            <option>Luis A.</option>
            <option>Ana R.</option>
            <option>Pedro S.</option>
          </select>
        </div>
        <div class="form-group">
          <label>Origen</label>
          <select class="form-control">
            <option>Inbound</option>
            <option>Outbound</option>
            <option>Referido</option>
            <option>Evento</option>
          </select>
        </div>
      </div>
      <div class="form-group">
        <label>Notas</label>
        <textarea class="form-control" placeholder="Detalles relevantes de la oportunidad…"></textarea>
      </div>
    </div>
    <div class="modal-footer">
      <button class="btn btn-secondary btn-sm" onclick="closeModal('modal-oportunidad')">Cancelar</button>
      <button class="btn btn-primary btn-sm">Crear Oportunidad</button>
    </div>
  </div>
</div>
</CRMLayout>
