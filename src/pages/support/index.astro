---
import CRMLayout from '../../layouts/CRMLayout.astro';

const tickets = [
  { id:'#1042', title:'Error en módulo de facturación',         client:'Tecno S.A.',     agent:'Carlos V.', created:'Hace 2h',   priority:'Crítico', status:'Abierto',     type:'Bug'       },
  { id:'#1041', title:'No puede iniciar sesión en el portal',   client:'Global Corp',    agent:'María P.',  created:'Hace 3h',   priority:'Alto',    status:'En proceso',  type:'Incidente' },
  { id:'#1040', title:'Solicitud exportar datos en Excel',      client:'NetSol Ltda.',   agent:'Luis A.',   created:'Hace 5h',   priority:'Medio',   status:'Abierto',     type:'Solicitud' },
  { id:'#1039', title:'Error de carga de contactos masivos',    client:'MegaTrade',      agent:'Ana R.',    created:'Hace 6h',   priority:'Alto',    status:'En proceso',  type:'Bug'       },
  { id:'#1038', title:'Consulta sobre integración con SAP',     client:'InnoTech',       agent:'Pedro S.',  created:'Ayer',      priority:'Medio',   status:'En espera',   type:'Consulta'  },
  { id:'#1037', title:'Panel de reportes no carga gráficas',    client:'FinGroup',       agent:'Carlos V.', created:'Ayer',      priority:'Medio',   status:'En proceso',  type:'Bug'       },
  { id:'#1036', title:'Agregar campo personalizado a lead',     client:'Retail Max',     agent:'María P.',  created:'2 días',    priority:'Bajo',    status:'Abierto',     type:'Mejora'    },
  { id:'#1035', title:'Precios actualizados en catálogo',       client:'DataPoint S.A.', agent:'Luis A.',   created:'2 días',    priority:'Bajo',    status:'Cerrado',     type:'Solicitud' },
  { id:'#1034', title:'Problema con email de bienvenida',       client:'Alpha IT',       agent:'Ana R.',    created:'3 días',    priority:'Medio',   status:'Cerrado',     type:'Incidente' },
];
const prioMap: Record<string,string> = { 'Crítico':'badge-red','Alto':'badge-orange','Medio':'badge-yellow','Bajo':'badge-gray' };
const statMap: Record<string,string> = { 'Abierto':'badge-blue','En proceso':'badge-yellow','En espera':'badge-purple','Cerrado':'badge-green' };
const typeMap: Record<string,string> = { 'Bug':'badge-red','Incidente':'badge-orange','Solicitud':'badge-navy','Consulta':'badge-blue','Mejora':'badge-purple' };
---
<CRMLayout title="Tickets">

  <div class="page-header">
    <div>
      <h1 class="page-title">Tickets de Soporte</h1>
      <p class="page-subtitle">Gestión de casos, incidencias y solicitudes de clientes</p>
    </div>
    <div class="gap-actions">
      <button class="btn btn-secondary btn-sm" onclick="openModal('modal-sla-report')">📊 SLA Report</button>
      <button class="btn btn-primary btn-sm" onclick="openModal('modal-ticket')">+ Nuevo Ticket</button>
    </div>
  </div>

  <div class="kpi-grid" style="grid-template-columns:repeat(5,1fr);">
    <div class="kpi-card kpi-blue">
      <div class="kpi-value">23</div><div class="kpi-label">Tickets abiertos</div>
      <div class="kpi-change down">↑ 3 sin respuesta</div>
    </div>
    <div class="kpi-card kpi-red">
      <div class="kpi-value">2</div><div class="kpi-label">Críticos</div>
      <div class="kpi-change down">Requieren atención</div>
    </div>
    <div class="kpi-card kpi-green">
      <div class="kpi-value">94%</div><div class="kpi-label">Satisfacción cliente</div>
      <div class="kpi-change up">↑ 2%</div>
    </div>
    <div class="kpi-card kpi-gold">
      <div class="kpi-value">4.2h</div><div class="kpi-label">Tiempo primera respuesta</div>
      <div class="kpi-change up">↓ 0.8h</div>
    </div>
    <div class="kpi-card kpi-orange">
      <div class="kpi-value">14h</div><div class="kpi-label">Tiempo resol. promedio</div>
      <div class="kpi-change up">↓ 2h</div>
    </div>
  </div>

  <!-- SLA Overview -->
  <div class="grid-3" style="margin-bottom:1.25rem;">
    <div class="card">
      <div class="card-header"><h3 class="card-title">SLA Conformidad</h3></div>
      <div class="card-body">
        {[
          { label:'Tiempo primera respuesta', val:91, target:'≤ 4h',  ok:true  },
          { label:'Tiempo resolución',        val:87, target:'≤ 24h', ok:true  },
          { label:'Disponibilidad sistema',   val:99.8,target:'≥ 99.5%',ok:true },
        ].map(s => (
          <div style="margin-bottom:0.9rem;">
            <div style="display:flex;justify-content:space-between;font-size:0.75rem;margin-bottom:4px;">
              <span class="font-medium">{s.label}</span>
              <span class={s.ok?'badge badge-green':'badge badge-red'}>{s.val}% (meta {s.target})</span>
            </div>
            <div class="progress-bar">
              <div class="progress-fill" style={`width:${s.val}%;background:${s.ok?'var(--success)':'var(--danger)'}`}></div>
            </div>
          </div>
        ))}
      </div>
    </div>

    <div class="card">
      <div class="card-header"><h3 class="card-title">Tickets por Tipo</h3></div>
      <div class="card-body">
        <div class="bar-chart-h">
          {[
            { label:'Bug',       val:32, pct:32, color:'var(--danger)'   },
            { label:'Solicitud', val:28, pct:28, color:'var(--primary-light)' },
            { label:'Consulta',  val:22, pct:22, color:'var(--info)'     },
            { label:'Incidente', val:12, pct:12, color:'var(--warning)'  },
            { label:'Mejora',    val: 6, pct: 6, color:'#7c3aed'         },
          ].map(r => (
            <div class="bar-chart-h-row">
              <span class="bar-chart-h-label">{r.label}</span>
              <div class="bar-chart-h-track">
                <div class="bar-chart-h-fill" style={`width:${r.pct*2.5}%;background:${r.color}`}></div>
              </div>
              <span class="bar-chart-h-val">{r.val}%</span>
            </div>
          ))}
        </div>
      </div>
    </div>

    <div class="card">
      <div class="card-header"><h3 class="card-title">Agentes — Carga de trabajo</h3></div>
      <div class="card-body">
        {[
          { name:'Carlos V.', open:8, closed:24, avatar:'CV' },
          { name:'María P.',  open:5, closed:31, avatar:'MP' },
          { name:'Luis A.',   open:4, closed:19, avatar:'LA' },
          { name:'Ana R.',    open:6, closed:22, avatar:'AR' },
          { name:'Pedro S.',  open:3, closed:15, avatar:'PS' },
        ].map(a => (
          <div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:0.65rem;">
            <div class="avatar">{a.avatar}</div>
            <div style="flex:1;">
              <div style="font-size:0.78rem;font-weight:600;">{a.name}</div>
              <div style="font-size:0.68rem;color:var(--text-muted);">{a.open} abiertos · {a.closed} cerrados</div>
            </div>
            <div class="progress-bar" style="width:60px;">
              <div class="progress-fill" style={`width:${Math.min(a.open*12,100)}%;background:${a.open>=7?'var(--danger)':a.open>=5?'var(--warning)':'var(--success)'}`}></div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- Toolbar -->
  <div class="toolbar">
    <div class="search-input-wrap">
      <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
      </svg>
      <input class="search-input" placeholder="Buscar ticket…">
    </div>
    <select class="form-control" style="width:auto;padding:0.47rem 0.75rem;">
      <option>Todos los estados</option>
      <option>Abierto</option><option>En proceso</option><option>En espera</option><option>Cerrado</option>
    </select>
    <select class="form-control" style="width:auto;padding:0.47rem 0.75rem;">
      <option>Todas las prioridades</option>
      <option>Crítico</option><option>Alto</option><option>Medio</option><option>Bajo</option>
    </select>
    <select class="form-control" style="width:auto;padding:0.47rem 0.75rem;">
      <option>Todos los agentes</option>
    </select>
    <div class="spacer"></div>
  </div>

  <div class="card">
    <div style="overflow-x:auto;">
      <table class="data-table">
        <thead>
          <tr>
            <th>ID</th>
            <th>Asunto</th>
            <th>Cliente</th>
            <th>Tipo</th>
            <th>Prioridad</th>
            <th>Estado</th>
            <th>Agente</th>
            <th>Creado</th>
            <th>Acciones</th>
          </tr>
        </thead>
        <tbody>
          {tickets.map(t => (
            <tr>
              <td style="font-family:monospace;font-size:0.72rem;font-weight:700;color:var(--primary);">{t.id}</td>
              <td style="font-weight:500;">{t.title}</td>
              <td class="text-muted text-xs">{t.client}</td>
              <td><span class={`badge ${typeMap[t.type]}`}>{t.type}</span></td>
              <td><span class={`badge ${prioMap[t.priority]}`}>{t.priority}</span></td>
              <td><span class={`badge ${statMap[t.status]}`}>{t.status}</span></td>
              <td>
                <div style="display:flex;align-items:center;gap:0.4rem;">
                  <div class="avatar" style="width:22px;height:22px;font-size:0.55rem;">{t.agent.split(' ').map(n=>n[0]).join('')}</div>
                  <span class="text-xs">{t.agent}</span>
                </div>
              </td>
              <td class="text-muted text-xs">{t.created}</td>
              <td>
                <div class="gap-actions">
                  <button class="btn btn-secondary btn-sm" onclick="openModal('modal-ver-ticket')">Abrir</button>
                  <button class="btn btn-ghost btn-sm btn-icon" onclick="openModal('modal-editar-ticket')">✏️</button>
                  <button class="btn btn-ghost btn-sm btn-icon" onclick="openModal('modal-acciones-ticket')">⋯</button>
                </div>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
    <div style="padding:0.875rem 1.25rem;border-top:1px solid var(--border);">
      <span class="text-muted text-xs">Mostrando 1-9 de 156 tickets</span>
    </div>
  </div>

<!-- Modal: Ver Ticket -->
<div class="modal-overlay" id="modal-ver-ticket">
  <div class="modal" style="max-width:680px;">
    <div class="modal-header">
      <div class="modal-title">🎫 Ticket #TKT-0156</div>
      <button class="modal-close" onclick="closeModal('modal-ver-ticket')">✕</button>
    </div>
    <div class="modal-body">
      <div style="display:flex;gap:1rem;margin-bottom:1rem;flex-wrap:wrap;">
        <span class="badge badge-orange">Abierto</span>
        <span class="badge badge-red">Alta prioridad</span>
        <span class="badge badge-blue">Bug</span>
        <span style="font-size:0.78rem;color:var(--text-muted);">Creado: 20 Mar 2026 · Asignado a: María López</span>
      </div>
      <div style="font-weight:600;font-size:0.95rem;margin-bottom:0.5rem;">Error en integración con Stripe al procesar reembolso</div>
      <div style="font-size:0.82rem;color:var(--text-muted);margin-bottom:1.25rem;background:#f8fafc;border:1px solid var(--border);border-radius:0.4rem;padding:0.75rem;">Al intentar procesar un reembolso parcial desde el panel de admin, el sistema arroja error 500 y no completa la transacción. El cliente reportó el problema el 19 Mar 2026.</div>
      <div style="font-size:0.8rem;font-weight:600;margin-bottom:0.75rem;">Historial del ticket</div>
      <div style="display:flex;flex-direction:column;gap:0.6rem;">
        <div style="display:flex;gap:0.75rem;align-items:flex-start;">
          <div class="avatar" style="width:28px;height:28px;font-size:0.6rem;flex-shrink:0;">ML</div>
          <div style="background:#f1f5f9;border-radius:0.4rem;padding:0.6rem 0.8rem;flex:1;">
            <div style="font-size:0.7rem;font-weight:600;margin-bottom:0.2rem;">María López <span style="color:var(--text-muted);font-weight:400;">20 Mar 2026, 10:22</span></div>
            <div style="font-size:0.78rem;">Ticket asignado. Investigando el problema con la API de Stripe.</div>
          </div>
        </div>
        <div style="display:flex;gap:0.75rem;align-items:flex-start;">
          <div class="avatar" style="width:28px;height:28px;font-size:0.6rem;flex-shrink:0;">CL</div>
          <div style="background:#f1f5f9;border-radius:0.4rem;padding:0.6rem 0.8rem;flex:1;">
            <div style="font-size:0.7rem;font-weight:600;margin-bottom:0.2rem;">Cliente <span style="color:var(--text-muted);font-weight:400;">20 Mar 2026, 14:05</span></div>
            <div style="font-size:0.78rem;">El problema sigue ocurriendo. Adjunto captura de pantalla del error.</div>
          </div>
        </div>
      </div>
      <div style="margin-top:1rem;">
        <label style="font-size:0.78rem;font-weight:600;display:block;margin-bottom:0.35rem;">Agregar respuesta</label>
        <textarea class="form-control" style="min-height:75px;" placeholder="Escribe una respuesta al cliente o nota interna..."></textarea>
        <div style="display:flex;gap:0.5rem;margin-top:0.5rem;">
          <label style="display:flex;align-items:center;gap:0.3rem;font-size:0.75rem;cursor:pointer;"><input type="checkbox"> Nota interna (no visible al cliente)</label>
        </div>
      </div>
    </div>
    <div class="modal-footer">
      <button class="btn btn-secondary btn-sm" onclick="closeModal('modal-ver-ticket')">Cerrar</button>
      <button class="btn btn-secondary btn-sm" onclick="closeModal('modal-ver-ticket');openModal('modal-editar-ticket')">✏️ Editar ticket</button>
      <button class="btn btn-primary btn-sm">📤 Enviar respuesta</button>
    </div>
  </div>
</div>

<!-- Modal: Editar Ticket -->
<div class="modal-overlay" id="modal-editar-ticket">
  <div class="modal">
    <div class="modal-header">
      <div class="modal-title">✏️ Editar Ticket #TKT-0156</div>
      <button class="modal-close" onclick="closeModal('modal-editar-ticket')">✕</button>
    </div>
    <div class="modal-body">
      <div class="form-row">
        <div class="form-group">
          <label>Asunto</label>
          <input class="form-control" value="Error en integración con Stripe al procesar reembolso">
        </div>
        <div class="form-group">
          <label>Estado</label>
          <select class="form-control">
            <option selected>Abierto</option>
            <option>En progreso</option>
            <option>Pendiente cliente</option>
            <option>Resuelto</option>
            <option>Cerrado</option>
          </select>
        </div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label>Prioridad</label>
          <select class="form-control">
            <option>Baja</option>
            <option>Media</option>
            <option selected>Alta</option>
            <option>Crítica</option>
          </select>
        </div>
        <div class="form-group">
          <label>Tipo</label>
          <select class="form-control">
            <option selected>Bug</option>
            <option>Consulta</option>
            <option>Feature request</option>
            <option>Soporte</option>
          </select>
        </div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label>Asignado a</label>
          <select class="form-control">
            <option selected>María López</option>
            <option>Carlos Ruiz</option>
            <option>Ana Torres</option>
          </select>
        </div>
        <div class="form-group">
          <label>SLA (horas)</label>
          <input class="form-control" type="number" value="4">
        </div>
      </div>
    </div>
    <div class="modal-footer">
      <button class="btn btn-secondary btn-sm" onclick="closeModal('modal-editar-ticket')">Cancelar</button>
      <button class="btn btn-primary btn-sm">💾 Guardar cambios</button>
    </div>
  </div>
</div>

<!-- Modal: Acciones Ticket -->
<div class="modal-overlay" id="modal-acciones-ticket">
  <div class="modal" style="max-width:360px;">
    <div class="modal-header">
      <div class="modal-title">⋯ Acciones de Ticket</div>
      <button class="modal-close" onclick="closeModal('modal-acciones-ticket')">✕</button>
    </div>
    <div class="modal-body" style="padding:0.5rem 0;gap:0;">
      <button class="menu-action-btn" onclick="closeModal('modal-acciones-ticket');openModal('modal-ver-ticket')">🎫 Ver detalle</button>
      <button class="menu-action-btn" onclick="closeModal('modal-acciones-ticket');openModal('modal-editar-ticket')">✏️ Editar ticket</button>
      <button class="menu-action-btn">📤 Enviar respuesta rápida</button>
      <button class="menu-action-btn">🔄 Reasignar agente</button>
      <button class="menu-action-btn">✅ Marcar como resuelto</button>
      <div style="border-top:1px solid var(--border);margin:0.4rem 0;"></div>
      <button class="menu-action-btn" style="color:var(--danger);">📏 Cerrar y archivar</button>
    </div>
  </div>
</div>

<!-- Modal: SLA Report -->
<div class="modal-overlay" id="modal-sla-report">
  <div class="modal" style="max-width:620px;">
    <div class="modal-header">
      <div class="modal-title">📊 Reporte SLA — Marzo 2026</div>
      <button class="modal-close" onclick="closeModal('modal-sla-report')">✕</button>
    </div>
    <div class="modal-body">
      <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:0.75rem;margin-bottom:1rem;">
        <div style="background:#f0fdf4;border-radius:0.5rem;padding:0.75rem;text-align:center;border:1px solid #bbf7d0;">
          <div style="font-size:1.4rem;font-weight:700;color:var(--success);">91%</div>
          <div style="font-size:0.72rem;color:var(--text-muted);">SLA cumplido</div>
        </div>
        <div style="background:#fff7ed;border-radius:0.5rem;padding:0.75rem;text-align:center;border:1px solid #fed7aa;">
          <div style="font-size:1.4rem;font-weight:700;color:var(--warning);">4.2h</div>
          <div style="font-size:0.72rem;color:var(--text-muted);">Tiempo promedio resp.</div>
        </div>
        <div style="background:#eff6ff;border-radius:0.5rem;padding:0.75rem;text-align:center;border:1px solid #bfdbfe;">
          <div style="font-size:1.4rem;font-weight:700;color:var(--info);">8.7h</div>
          <div style="font-size:0.72rem;color:var(--text-muted);">Tiempo promedio cierre</div>
        </div>
      </div>
      <table style="width:100%;border-collapse:collapse;font-size:0.8rem;">
        <thead><tr style="background:#f8fafc;"><th style="padding:0.5rem;text-align:left;">Agente</th><th style="padding:0.5rem;text-align:right;">Tickets</th><th style="padding:0.5rem;text-align:right;">SLA %</th><th style="padding:0.5rem;text-align:right;">Prom. cierre</th></tr></thead>
        <tbody>
          <tr style="border-top:1px solid var(--border);"><td style="padding:0.5rem;">María López</td><td style="padding:0.5rem;text-align:right;">42</td><td style="padding:0.5rem;text-align:right;color:var(--success);">95%</td><td style="padding:0.5rem;text-align:right;">7.2h</td></tr>
          <tr style="border-top:1px solid var(--border);"><td style="padding:0.5rem;">Carlos Ruiz</td><td style="padding:0.5rem;text-align:right;">38</td><td style="padding:0.5rem;text-align:right;color:var(--warning);">87%</td><td style="padding:0.5rem;text-align:right;">9.8h</td></tr>
          <tr style="border-top:1px solid var(--border);"><td style="padding:0.5rem;">Ana Torres</td><td style="padding:0.5rem;text-align:right;">35</td><td style="padding:0.5rem;text-align:right;color:var(--success);">91%</td><td style="padding:0.5rem;text-align:right;">8.1h</td></tr>
        </tbody>
      </table>
    </div>
    <div class="modal-footer">
      <button class="btn btn-secondary btn-sm" onclick="closeModal('modal-sla-report')">Cerrar</button>
      <button class="btn btn-primary btn-sm">⬇️ Exportar PDF</button>
    </div>
  </div>
</div>

<!-- Modal: Nuevo Ticket -->
<div class="modal-overlay" id="modal-ticket">
  <div class="modal">
    <div class="modal-header">
      <div class="modal-title">🎫 Nuevo Ticket</div>
      <button class="modal-close" onclick="closeModal('modal-ticket')">✕</button>
    </div>
    <div class="modal-body">
      <div class="form-group">
        <label>Título del problema</label>
        <input class="form-control" type="text" placeholder="Descripción breve del problema">
      </div>
      <div class="form-row">
        <div class="form-group">
          <label>Cliente</label>
          <input class="form-control" type="text" placeholder="Nombre del cliente">
        </div>
        <div class="form-group">
          <label>Empresa</label>
          <input class="form-control" type="text" placeholder="Empresa del cliente">
        </div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label>Tipo</label>
          <select class="form-control">
            <option>Bug</option>
            <option>Consulta</option>
            <option>Mejora</option>
            <option>Instalación</option>
            <option>Capacitación</option>
          </select>
        </div>
        <div class="form-group">
          <label>Prioridad</label>
          <select class="form-control">
            <option>Medio</option>
            <option>Bajo</option>
            <option>Alto</option>
            <option>Urgente</option>
          </select>
        </div>
      </div>
      <div class="form-group">
        <label>Agente asignado</label>
        <select class="form-control">
          <option>Carlos V.</option>
          <option>María P.</option>
          <option>Luis A.</option>
          <option>Ana R.</option>
          <option>Pedro S.</option>
        </select>
      </div>
      <div class="form-group">
        <label>Descripción detallada</label>
        <textarea class="form-control" placeholder="Describe el problema o solicitud con el mayor detalle posible…"></textarea>
      </div>
    </div>
    <div class="modal-footer">
      <button class="btn btn-secondary btn-sm" onclick="closeModal('modal-ticket')">Cancelar</button>
      <button class="btn btn-primary btn-sm">Abrir Ticket</button>
    </div>
  </div>
</div>

</CRMLayout>
