---
import CRMLayout from '../../layouts/CRMLayout.astro';

const campaigns = [
  { id:1, name:'Newsletter Q1 2026',       type:'Email',    status:'Activa',    sent:4820, opens:1640, clicks:312, conv:48, budget:'$800',   roi:'620%', start:'01 Feb',end:'30 Mar' },
  { id:2, name:'LinkedIn Lead Gen Mar',    type:'Social',   status:'Activa',    sent:12400,opens:3200, clicks:680, conv:22, budget:'$1,200', roi:'280%', start:'01 Mar',end:'31 Mar' },
  { id:3, name:'Google Ads - Enterprise',  type:'PPC',      status:'Activa',    sent:28000,opens:4200, clicks:920, conv:18, budget:'$2,500', roi:'210%', start:'15 Feb',end:'15 Abr' },
  { id:4, name:'Expo Tech 2026',           type:'Evento',   status:'Completada',sent:500,  opens:350,  clicks:180, conv:32, budget:'$3,200', roi:'185%', start:'20 Feb',end:'22 Feb' },
  { id:5, name:'Webinar CRM Best Practices',type:'Webinar', status:'Programada',sent:1200, opens:0,    clicks:0,   conv:0,  budget:'$600',   roi:'—',    start:'15 Mar',end:'15 Mar' },
];
---
<CRMLayout title="Campañas">

  <div class="page-header">
    <div>
      <h1 class="page-title">Campañas de Marketing</h1>
      <p class="page-subtitle">Planificación, ejecución y medición de campañas</p>
    </div>
    <div class="gap-actions">
      <button class="btn btn-secondary btn-sm" onclick="openModal('modal-analytics-campanas')">📊 Analytics</button>
      <button class="btn btn-primary btn-sm" onclick="openModal('modal-campana')">+ Nueva Campaña</button>
    </div>
  </div>

  <div class="kpi-grid" style="grid-template-columns:repeat(5,1fr);">
    <div class="kpi-card kpi-blue">
      <div class="kpi-value">5</div><div class="kpi-label">Campañas activas</div>
    </div>
    <div class="kpi-card kpi-gold">
      <div class="kpi-value">46,920</div><div class="kpi-label">Alcance total</div>
      <div class="kpi-change up">↑ 12%</div>
    </div>
    <div class="kpi-card kpi-green">
      <div class="kpi-value">120</div><div class="kpi-label">Conversiones</div>
      <div class="kpi-change up">↑ 18%</div>
    </div>
    <div class="kpi-card kpi-orange">
      <div class="kpi-value">$8,300</div><div class="kpi-label">Gasto total</div>
    </div>
    <div class="kpi-card kpi-purple">
      <div class="kpi-value">324%</div><div class="kpi-label">ROI promedio</div>
      <div class="kpi-change up">↑ 40%</div>
    </div>
  </div>

  <div class="tabs" style="margin-bottom:1.25rem;">
    <a class="tab active" href="#">Todas</a>
    <a class="tab" href="#">Email</a>
    <a class="tab" href="#">Social</a>
    <a class="tab" href="#">PPC / Ads</a>
    <a class="tab" href="#">Eventos</a>
    <a class="tab" href="#">Webinars</a>
  </div>

  <!-- Campaign cards -->
  <div style="display:flex;flex-direction:column;gap:1rem;">
    {campaigns.map(c => (
      <div class="card">
        <div style="display:flex;align-items:center;gap:1.25rem;padding:1.25rem;">
          <!-- Type icon -->
          <div style="width:48px;height:48px;background:#e8f0f9;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:1.4rem;flex-shrink:0;">
            {c.type==='Email'?'📧':c.type==='Social'?'📱':c.type==='PPC'?'💰':c.type==='Evento'?'🎪':'🎥'}
          </div>

          <div style="flex:1;min-width:0;">
            <div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:0.3rem;">
              <span style="font-size:0.9rem;font-weight:700;">{c.name}</span>
              <span class={`badge ${c.status==='Activa'?'badge-green':c.status==='Completada'?'badge-blue':'badge-yellow'}`}>{c.status}</span>
              <span class="badge badge-navy">{c.type}</span>
            </div>
            <div style="font-size:0.72rem;color:var(--text-muted);">{c.start} → {c.end} &nbsp;|&nbsp; Presupuesto: {c.budget} &nbsp;|&nbsp; ROI: <span style="font-weight:700;color:var(--success);">{c.roi}</span></div>
          </div>

          <!-- Metrics -->
          <div style="display:flex;gap:2rem;flex-shrink:0;">
            {[
              { label:'Alcance',     val: c.sent.toLocaleString()  },
              { label:'Aperturas',   val: c.opens.toLocaleString() },
              { label:'Clics',       val: c.clicks.toLocaleString()},
              { label:'Conversiones',val: c.conv.toString()        },
            ].map(m => (
              <div style="text-align:center;">
                <div style="font-size:1rem;font-weight:700;">{m.val}</div>
                <div style="font-size:0.65rem;color:var(--text-muted);margin-top:2px;">{m.label}</div>
              </div>
            ))}
          </div>

          <div class="gap-actions" style="flex-shrink:0;">
            <button class="btn btn-secondary btn-sm" onclick="openModal('modal-resultados-campana')">📊 Ver resultados</button>
            <button class="btn btn-ghost btn-sm btn-icon" onclick="openModal('modal-editar-campana')">✏️</button>
          </div>
        </div>

        <!-- Progress bars -->
        <div style="padding:0 1.25rem 1rem;display:grid;grid-template-columns:repeat(3,1fr);gap:0.75rem;">
          {c.opens > 0 && [
            { label:'Tasa apertura', val: Math.round(c.opens/c.sent*100), color:'var(--primary-light)' },
            { label:'CTR',           val: Math.round(c.clicks/c.opens*100), color:'var(--accent)' },
            { label:'Conversión',    val: Math.round(c.conv/c.clicks*100),  color:'var(--success)' },
          ].map(bar => (
            <div>
              <div style="display:flex;justify-content:space-between;font-size:0.68rem;margin-bottom:3px;">
                <span class="text-muted">{bar.label}</span>
                <span class="font-semibold">{bar.val}%</span>
              </div>
              <div class="progress-bar">
                <div class="progress-fill" style={`width:${Math.min(bar.val*2,100)}%;background:${bar.color}`}></div>
              </div>
            </div>
          ))}
        </div>
      </div>
    ))}
  </div>

<!-- Modal: Resultados Campaña -->
<div class="modal-overlay" id="modal-resultados-campana">
  <div class="modal" style="max-width:640px;">
    <div class="modal-header">
      <div class="modal-title">📊 Resultados — Q1 Product Launch</div>
      <button class="modal-close" onclick="closeModal('modal-resultados-campana')">✕</button>
    </div>
    <div class="modal-body">
      <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:0.6rem;margin-bottom:1rem;">
        {[{label:'Enviados',val:'12,400',color:'var(--info)'},{label:'Abiertos',val:'3,472',color:'var(--primary)'},{label:'Clicks',val:'867',color:'var(--accent)'},{label:'Conversiones',val:'124',color:'var(--success)'}].map(m => (
          <div style="background:#f8fafc;border-radius:0.4rem;padding:0.65rem;text-align:center;border:1px solid var(--border);">
            <div style={`font-size:1.1rem;font-weight:700;color:${m.color};`}>{m.val}</div>
            <div style="font-size:0.7rem;color:var(--text-muted);">{m.label}</div>
          </div>
        ))}
      </div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:0.75rem;margin-bottom:0.75rem;font-size:0.8rem;">
        <div style="background:#f8fafc;border-radius:0.4rem;padding:0.65rem;">
          <div style="font-weight:600;margin-bottom:0.4rem;">Tasas clave</div>
          <div style="display:flex;justify-content:space-between;"><span style="color:var(--text-muted);">Apertura</span><span style="font-weight:600;">28.0%</span></div>
          <div style="display:flex;justify-content:space-between;"><span style="color:var(--text-muted);">CTR</span><span style="font-weight:600;">24.9%</span></div>
          <div style="display:flex;justify-content:space-between;"><span style="color:var(--text-muted);">Conversión</span><span style="font-weight:600;">14.3%</span></div>
        </div>
        <div style="background:#f8fafc;border-radius:0.4rem;padding:0.65rem;">
          <div style="font-weight:600;margin-bottom:0.4rem;">ROI de campaña</div>
          <div style="display:flex;justify-content:space-between;"><span style="color:var(--text-muted);">Inversión</span><span style="font-weight:600;">$4,800</span></div>
          <div style="display:flex;justify-content:space-between;"><span style="color:var(--text-muted);">Ingresos generados</span><span style="font-weight:600;color:var(--success);">$54,000</span></div>
          <div style="display:flex;justify-content:space-between;"><span style="color:var(--text-muted);">ROI</span><span style="font-weight:700;color:var(--success);">11.25x</span></div>
        </div>
      </div>
    </div>
    <div class="modal-footer">
      <button class="btn btn-secondary btn-sm" onclick="closeModal('modal-resultados-campana')">Cerrar</button>
      <button class="btn btn-primary btn-sm">⬇️ Exportar reporte</button>
    </div>
  </div>
</div>

<!-- Modal: Editar Campaña -->
<div class="modal-overlay" id="modal-editar-campana">
  <div class="modal">
    <div class="modal-header">
      <div class="modal-title">✏️ Editar Campaña</div>
      <button class="modal-close" onclick="closeModal('modal-editar-campana')">✕</button>
    </div>
    <div class="modal-body">
      <div class="form-row">
        <div class="form-group">
          <label>Nombre de la campaña</label>
          <input class="form-control" value="Q1 Product Launch">
        </div>
        <div class="form-group">
          <label>Tipo</label>
          <select class="form-control">
            <option selected>Email</option>
            <option>WhatsApp</option>
            <option>SMS</option>
            <option>LinkedIn</option>
          </select>
        </div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label>Fecha inicio</label>
          <input class="form-control" type="date" value="2026-03-01">
        </div>
        <div class="form-group">
          <label>Fecha fin</label>
          <input class="form-control" type="date" value="2026-03-31">
        </div>
      </div>
      <div class="form-group">
        <label>Estado</label>
        <select class="form-control">
          <option selected>Activa</option>
          <option>Pausada</option>
          <option>Borrador</option>
          <option>Completada</option>
        </select>
      </div>
      <div class="form-group">
        <label>Presupuesto</label>
        <input class="form-control" type="number" value="4800">
      </div>
    </div>
    <div class="modal-footer">
      <button class="btn btn-secondary btn-sm" onclick="closeModal('modal-editar-campana')">Cancelar</button>
      <button class="btn btn-primary btn-sm">💾 Guardar cambios</button>
    </div>
  </div>
</div>

<!-- Modal: Analytics Campañas -->
<div class="modal-overlay" id="modal-analytics-campanas">
  <div class="modal" style="max-width:660px;">
    <div class="modal-header">
      <div class="modal-title">📊 Analytics de Campañas — 2026</div>
      <button class="modal-close" onclick="closeModal('modal-analytics-campanas')">✕</button>
    </div>
    <div class="modal-body">
      <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:0.6rem;margin-bottom:1rem;">
        {[{label:'Total enviados',val:'45,200',color:'var(--info)'},{label:'Total conversiones',val:'512',color:'var(--success)'},{label:'ROI promedio',val:'8.4x',color:'var(--accent)'}].map(m => (
          <div style="background:#f8fafc;border-radius:0.4rem;padding:0.65rem;text-align:center;border:1px solid var(--border);">
            <div style={`font-size:1.1rem;font-weight:700;color:${m.color};`}>{m.val}</div>
            <div style="font-size:0.7rem;color:var(--text-muted);">{m.label}</div>
          </div>
        ))}
      </div>
      <table style="width:100%;border-collapse:collapse;font-size:0.8rem;">
        <thead><tr style="background:#f8fafc;"><th style="padding:0.5rem;text-align:left;">Campaña</th><th style="padding:0.5rem;text-align:right;">Enviados</th><th style="padding:0.5rem;text-align:right;">Conv.</th><th style="padding:0.5rem;text-align:right;">ROI</th></tr></thead>
        <tbody>
          {[['Q1 Product Launch','12,400','124','11.25x'],['Email Nurturing B2B','8,200','89','6.1x'],['LinkedIn Outreach','3,500','42','8.8x']].map(([name,sent,conv,roi]) => (
            <tr style="border-top:1px solid var(--border);"><td style="padding:0.5rem;font-weight:500;">{name}</td><td style="padding:0.5rem;text-align:right;">{sent}</td><td style="padding:0.5rem;text-align:right;color:var(--success);">{conv}</td><td style="padding:0.5rem;text-align:right;font-weight:600;color:var(--accent);">{roi}</td></tr>
          ))}
        </tbody>
      </table>
    </div>
    <div class="modal-footer">
      <button class="btn btn-secondary btn-sm" onclick="closeModal('modal-analytics-campanas')">Cerrar</button>
      <button class="btn btn-primary btn-sm">⬇️ Exportar analytics</button>
    </div>
  </div>
</div>

<!-- Modal: Nueva Campaña -->
<div class="modal-overlay" id="modal-campana">
  <div class="modal">
    <div class="modal-header">
      <div class="modal-title">📣 Nueva Campaña</div>
      <button class="modal-close" onclick="closeModal('modal-campana')">✕</button>
    </div>
    <div class="modal-body">
      <div class="form-group">
        <label>Nombre de la campaña</label>
        <input class="form-control" type="text" placeholder="Ej: Newsletter Q2 2026">
      </div>
      <div class="form-row">
        <div class="form-group">
          <label>Tipo</label>
          <select class="form-control">
            <option>Email</option>
            <option>Redes Sociales</option>
            <option>Evento</option>
            <option>Webinar</option>
            <option>PPC</option>
          </select>
        </div>
        <div class="form-group">
          <label>Estado inicial</label>
          <select class="form-control">
            <option>Borrador</option>
            <option>Planificada</option>
            <option>Activa</option>
          </select>
        </div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label>Fecha de inicio</label>
          <input class="form-control" type="date">
        </div>
        <div class="form-group">
          <label>Fecha de fin</label>
          <input class="form-control" type="date">
        </div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label>Presupuesto ($)</label>
          <input class="form-control" type="text" placeholder="$0">
        </div>
        <div class="form-group">
          <label>Objetivo</label>
          <input class="form-control" type="text" placeholder="Ej: 500 leads">
        </div>
      </div>
      <div class="form-group">
        <label>Responsable</label>
        <select class="form-control">
          <option>Carlos V.</option>
          <option>María P.</option>
          <option>Luis A.</option>
          <option>Ana R.</option>
        </select>
      </div>
      <div class="form-group">
        <label>Descripción</label>
        <textarea class="form-control" placeholder="Objetivo y descripción de la campaña…"></textarea>
      </div>
    </div>
    <div class="modal-footer">
      <button class="btn btn-secondary btn-sm" onclick="closeModal('modal-campana')">Cancelar</button>
      <button class="btn btn-primary btn-sm">Crear Campaña</button>
    </div>
  </div>
</div>

</CRMLayout>
