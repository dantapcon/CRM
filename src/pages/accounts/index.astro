---
import CRMLayout from '../../layouts/CRMLayout.astro';

const accounts = [
  { id:1,  name:'Tecno S.A.',       industry:'Tecnología',     type:'Cliente',    contacts:8,  revenue:'$34,200', potential:'$80k',  status:'Activo',    owner:'Carlos V.',   updated:'1h'     },
  { id:2,  name:'Global Corp',      industry:'Manufactura',    type:'Cliente',    contacts:12, revenue:'$28,100', potential:'$60k',  status:'Activo',    owner:'María P.',    updated:'3h'     },
  { id:3,  name:'NetSol Ltda.',     industry:'Software',       type:'Prospect',   contacts:3,  revenue:'$0',      potential:'$40k',  status:'Activo',    owner:'Luis A.',     updated:'1d'     },
  { id:4,  name:'DataPoint S.A.',   industry:'Datos/BI',       type:'Inactivo',   contacts:5,  revenue:'$12,400', potential:'$25k',  status:'Inactivo',  owner:'Ana R.',      updated:'1 sem.' },
  { id:5,  name:'MegaTrade',        industry:'Comercio',       type:'Cliente',    contacts:6,  revenue:'$17,500', potential:'$45k',  status:'Activo',    owner:'Pedro S.',    updated:'2h'     },
  { id:6,  name:'SoftCo',          industry:'Software',       type:'Ex-cliente', contacts:2,  revenue:'$5,000',  potential:'$15k',  status:'Inactivo',  owner:'María P.',    updated:'2 sem.' },
  { id:7,  name:'InnoTech',         industry:'Tecnología',     type:'Prospect',   contacts:4,  revenue:'$0',      potential:'$30k',  status:'Activo',    owner:'Carlos V.',   updated:'4d'     },
  { id:8,  name:'Logística Plus',   industry:'Logística',      type:'Lead',       contacts:1,  revenue:'$0',      potential:'$20k',  status:'Nuevo',     owner:'Luis A.',     updated:'2 sem.' },
  { id:9,  name:'FinGroup',         industry:'Finanzas',       type:'Cliente',    contacts:9,  revenue:'$22,800', potential:'$55k',  status:'Activo',    owner:'Ana R.',      updated:'1d'     },
  { id:10, name:'Retail Max',       industry:'Retail',         type:'Prospect',   contacts:3,  revenue:'$0',      potential:'$35k',  status:'Activo',    owner:'Pedro S.',    updated:'5d'     },
];
---
<CRMLayout title="Cuentas">

  <div class="page-header">
    <div>
      <h1 class="page-title">Cuentas / Empresas</h1>
      <p class="page-subtitle">Gestión de empresas, organizaciones y clientes corporativos</p>
    </div>
    <div class="gap-actions">
      <button class="btn btn-secondary btn-sm" onclick="openModal('modal-importar-cuentas')">📤 Importar</button>
      <button class="btn btn-secondary btn-sm" onclick="openModal('modal-exportar-cuentas')">📥 Exportar</button>
      <button class="btn btn-primary btn-sm" onclick="openModal('modal-cuenta')">+ Nueva Cuenta</button>
    </div>
  </div>

  <div class="kpi-grid" style="grid-template-columns:repeat(4,1fr);">
    <div class="kpi-card kpi-blue">
      <div class="kpi-value">342</div><div class="kpi-label">Total Cuentas</div>
      <div class="kpi-change up">↑ 12 este mes</div>
    </div>
    <div class="kpi-card kpi-green">
      <div class="kpi-value">198</div><div class="kpi-label">Clientes Activos</div>
      <div class="kpi-change up">↑ 6 nuevos</div>
    </div>
    <div class="kpi-card kpi-gold">
      <div class="kpi-value">$120,000</div><div class="kpi-label">Ingresos (MTD)</div>
      <div class="kpi-change up">↑ 18%</div>
    </div>
    <div class="kpi-card kpi-orange">
      <div class="kpi-value">$450,000</div><div class="kpi-label">Pipeline Total</div>
      <div class="kpi-change up">↑ 5.4%</div>
    </div>
  </div>

  <div class="toolbar">
    <div class="search-input-wrap">
      <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
      </svg>
      <input class="search-input" placeholder="Buscar empresa…">
    </div>
    <select class="form-control" style="width:auto;padding:0.47rem 0.75rem;">
      <option>Todos los tipos</option>
      <option>Cliente</option><option>Prospect</option><option>Lead</option><option>Ex-cliente</option>
    </select>
    <select class="form-control" style="width:auto;padding:0.47rem 0.75rem;">
      <option>Todas las industrias</option>
      <option>Tecnología</option><option>Manufactura</option><option>Software</option><option>Finanzas</option>
    </select>
    <select class="form-control" style="width:auto;padding:0.47rem 0.75rem;">
      <option>Todos los responsables</option>
    </select>
    <div class="spacer"></div>
    <span class="text-muted text-xs">342 registros</span>
  </div>

  <div class="card">
    <div style="overflow-x:auto;">
      <table class="data-table">
        <thead>
          <tr>
            <th><input type="checkbox"></th>
            <th>Empresa</th>
            <th>Industria</th>
            <th>Tipo</th>
            <th>Contactos</th>
            <th>Ingresos</th>
            <th>Potencial</th>
            <th>Estado</th>
            <th>Responsable</th>
            <th>Actualizado</th>
            <th>Acciones</th>
          </tr>
        </thead>
        <tbody>
          {accounts.map(a => (
            <tr>
              <td><input type="checkbox"></td>
              <td>
                <div style="display:flex;align-items:center;gap:0.6rem;">
                  <div style="width:32px;height:32px;background:#e8f0f9;border-radius:6px;display:flex;align-items:center;justify-content:center;font-size:0.8rem;font-weight:700;color:var(--primary);">
                    {a.name[0]}
                  </div>
                  <a href={`/accounts/${a.id}`} style="font-weight:600;color:var(--primary);text-decoration:none;">{a.name}</a>
                </div>
              </td>
              <td class="text-muted">{a.industry}</td>
              <td>
                <span class={`badge ${a.type==='Cliente'?'badge-green':a.type==='Prospect'?'badge-blue':a.type==='Lead'?'badge-yellow':'badge-gray'}`}>{a.type}</span>
              </td>
              <td style="text-align:center;">{a.contacts}</td>
              <td class="font-semibold">{a.revenue}</td>
              <td style="color:var(--success);font-weight:600;">{a.potential}</td>
              <td>
                <span class={`badge ${a.status==='Activo'?'badge-green':a.status==='Nuevo'?'badge-navy':'badge-gray'}`}>{a.status}</span>
              </td>
              <td class="text-muted text-xs">{a.owner}</td>
              <td class="text-muted text-xs">{a.updated}</td>
              <td>
                <div class="gap-actions">
                  <button class="btn btn-ghost btn-sm btn-icon" title="Ver" onclick="openModal('modal-ver-cuenta')">👁</button>
                  <button class="btn btn-ghost btn-sm btn-icon" title="Editar" onclick="openModal('modal-editar-cuenta')">✏️</button>
                  <button class="btn btn-ghost btn-sm btn-icon" title="Más" onclick="openModal('modal-acciones-cuenta')">⋯</button>
                </div>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
    <div style="display:flex;align-items:center;justify-content:space-between;padding:0.875rem 1.25rem;border-top:1px solid var(--border);">
      <span class="text-muted text-xs">Mostrando 1-10 de 342 cuentas</span>
      <div class="gap-actions">
        <button class="btn btn-secondary btn-sm">← Anterior</button>
        <button class="btn btn-primary btn-sm">1</button>
        <button class="btn btn-secondary btn-sm">2</button>
        <button class="btn btn-secondary btn-sm">3</button>
        <button class="btn btn-secondary btn-sm">Siguiente →</button>
      </div>
    </div>
  </div>

<!-- Modal: Importar Cuentas -->
<div class="modal-overlay" id="modal-importar-cuentas">
  <div class="modal">
    <div class="modal-header">
      <div class="modal-title">📤 Importar Cuentas</div>
      <button class="modal-close" onclick="closeModal('modal-importar-cuentas')">✕</button>
    </div>
    <div class="modal-body">
      <div style="border:2px dashed var(--border);border-radius:0.5rem;padding:1.5rem;text-align:center;margin-bottom:0.75rem;cursor:pointer;" onclick="this.querySelector('input').click()">
        <div style="font-size:2rem;margin-bottom:0.5rem;">📄</div>
        <div style="font-weight:600;font-size:0.88rem;">Arrastra tu archivo aquí o haz clic para seleccionar</div>
        <div style="font-size:0.72rem;color:var(--text-muted);margin-top:0.25rem;">CSV o Excel (.xlsx) — máx. 5 MB</div>
        <input type="file" accept=".csv,.xlsx" style="display:none;">
      </div>
      <div class="form-group">
        <label>Acción si la cuenta ya existe</label>
        <select class="form-control">
          <option selected>Actualizar campos vacíos</option>
          <option>Sobreescribir todo</option>
          <option>Omitir duplicados</option>
        </select>
      </div>
      <a href="#" style="font-size:0.75rem;color:var(--primary);">⬇️ Descargar plantilla CSV</a>
    </div>
    <div class="modal-footer">
      <button class="btn btn-secondary btn-sm" onclick="closeModal('modal-importar-cuentas')">Cancelar</button>
      <button class="btn btn-primary btn-sm">📤 Importar cuentas</button>
    </div>
  </div>
</div>

<!-- Modal: Exportar Cuentas -->
<div class="modal-overlay" id="modal-exportar-cuentas">
  <div class="modal" style="max-width:420px;">
    <div class="modal-header">
      <div class="modal-title">📥 Exportar Cuentas</div>
      <button class="modal-close" onclick="closeModal('modal-exportar-cuentas')">✕</button>
    </div>
    <div class="modal-body">
      <div class="form-group">
        <label>Formato</label>
        <select class="form-control">
          <option selected>CSV</option>
          <option>Excel (.xlsx)</option>
        </select>
      </div>
      <div class="form-group">
        <label>Registros a exportar</label>
        <select class="form-control">
          <option selected>Todas las cuentas (364)</option>
          <option>Solo filtro actual</option>
          <option>Solo seleccionadas</option>
        </select>
      </div>
      <div class="form-group">
        <label>Campos a incluir</label>
        <div style="display:flex;flex-direction:column;gap:0.35rem;">
          {['Nombre de empresa','Industria','Ingresos anuales','Contacto principal','Teléfono','Email','País'].map(f => (
            <label style="display:flex;align-items:center;gap:0.5rem;font-size:0.78rem;cursor:pointer;">
              <input type="checkbox" checked> {f}
            </label>
          ))}
        </div>
      </div>
    </div>
    <div class="modal-footer">
      <button class="btn btn-secondary btn-sm" onclick="closeModal('modal-exportar-cuentas')">Cancelar</button>
      <button class="btn btn-primary btn-sm">⬇️ Exportar ahora</button>
    </div>
  </div>
</div>

<!-- Modal: Ver Cuenta -->
<div class="modal-overlay" id="modal-ver-cuenta">
  <div class="modal" style="max-width:680px;">
    <div class="modal-header">
      <div class="modal-title">🏢 Detalle de la Cuenta</div>
      <button class="modal-close" onclick="closeModal('modal-ver-cuenta')">✕</button>
    </div>
    <div class="modal-body">
      <div style="display:flex;align-items:center;gap:1rem;padding-bottom:1rem;border-bottom:1px solid var(--border);margin-bottom:1rem;">
        <div style="width:56px;height:56px;background:#e8f0f9;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:1.4rem;font-weight:700;color:var(--primary);flex-shrink:0;">T</div>
        <div style="flex:1;">
          <div style="font-size:1.1rem;font-weight:700;">Tecno S.A.</div>
          <div style="font-size:0.8rem;color:var(--text-muted);">Tecnología · Cliente activo</div>
          <div style="display:flex;gap:0.5rem;margin-top:0.4rem;">
            <span class="badge badge-green">Activo</span>
            <span class="badge badge-blue">8 contactos</span>
          </div>
        </div>
        <button class="btn btn-primary btn-sm" onclick="closeModal('modal-ver-cuenta');openModal('modal-editar-cuenta')">✏️ Editar</button>
      </div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:0.75rem;margin-bottom:1rem;">
        <div style="background:#f8fafc;border-radius:0.5rem;padding:0.75rem;">
          <div style="font-size:0.65rem;font-weight:600;color:var(--text-muted);text-transform:uppercase;margin-bottom:0.3rem;">Ingresos</div>
          <div style="font-size:1rem;font-weight:700;color:var(--success);">$34,200</div>
        </div>
        <div style="background:#f8fafc;border-radius:0.5rem;padding:0.75rem;">
          <div style="font-size:0.65rem;font-weight:600;color:var(--text-muted);text-transform:uppercase;margin-bottom:0.3rem;">Potencial</div>
          <div style="font-size:1rem;font-weight:700;color:var(--warning);">$80k</div>
        </div>
        <div style="background:#f8fafc;border-radius:0.5rem;padding:0.75rem;">
          <div style="font-size:0.65rem;font-weight:600;color:var(--text-muted);text-transform:uppercase;margin-bottom:0.3rem;">Responsable</div>
          <div style="font-size:0.82rem;">Carlos V.</div>
        </div>
        <div style="background:#f8fafc;border-radius:0.5rem;padding:0.75rem;">
          <div style="font-size:0.65rem;font-weight:600;color:var(--text-muted);text-transform:uppercase;margin-bottom:0.3rem;">Última actualización</div>
          <div style="font-size:0.82rem;">Hace 1h</div>
        </div>
      </div>
      <div style="display:flex;gap:0.75rem;flex-direction:column;">
        <div style="font-size:0.75rem;font-weight:600;color:var(--text-muted);text-transform:uppercase;">Oportunidades activas</div>
        <div style="background:#f8fafc;border-radius:0.5rem;padding:0.75rem;font-size:0.82rem;">
          <div style="display:flex;justify-content:space-between;align-items:center;">
            <span class="font-semibold">Software Suite — Propuesta</span>
            <span class="badge badge-gold">$28,500</span>
          </div>
        </div>
      </div>
    </div>
    <div class="modal-footer">
      <button class="btn btn-secondary btn-sm" onclick="closeModal('modal-ver-cuenta')">Cerrar</button>
      <button class="btn btn-primary btn-sm" onclick="closeModal('modal-ver-cuenta');openModal('modal-cuenta')">✚ Nueva oportunidad</button>
    </div>
  </div>
</div>

<!-- Modal: Editar Cuenta -->
<div class="modal-overlay" id="modal-editar-cuenta">
  <div class="modal">
    <div class="modal-header">
      <div class="modal-title">✏️ Editar Cuenta</div>
      <button class="modal-close" onclick="closeModal('modal-editar-cuenta')">✕</button>
    </div>
    <div class="modal-body">
      <div class="form-group">
        <label>Nombre de la empresa</label>
        <input class="form-control" type="text" value="Tecno S.A.">
      </div>
      <div class="form-row">
        <div class="form-group">
          <label>Industria</label>
          <select class="form-control">
            <option selected>Tecnología</option><option>Manufactura</option><option>Retail</option><option>Finanzas</option>
          </select>
        </div>
        <div class="form-group">
          <label>Tipo</label>
          <select class="form-control">
            <option selected>Cliente</option><option>Prospecto</option><option>Lead</option><option>Partner</option>
          </select>
        </div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label>Email</label>
          <input class="form-control" type="email" value="contacto@tecno.com">
        </div>
        <div class="form-group">
          <label>Teléfono</label>
          <input class="form-control" type="tel" value="+57 1 234 5678">
        </div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label>Sitio web</label>
          <input class="form-control" value="https://tecno.com">
        </div>
        <div class="form-group">
          <label>Ciudad</label>
          <input class="form-control" value="Bogotá">
        </div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label>Potencial de ingresos</label>
          <input class="form-control" value="$80,000">
        </div>
        <div class="form-group">
          <label>Responsable</label>
          <select class="form-control">
            <option selected>Carlos V.</option><option>María P.</option><option>Luis A.</option><option>Ana R.</option>
          </select>
        </div>
      </div>
    </div>
    <div class="modal-footer">
      <button class="btn btn-secondary btn-sm" onclick="closeModal('modal-editar-cuenta')">Cancelar</button>
      <button class="btn btn-primary btn-sm">💾 Guardar Cambios</button>
    </div>
  </div>
</div>

<!-- Modal: Acciones Cuenta -->
<div class="modal-overlay" id="modal-acciones-cuenta">
  <div class="modal" style="max-width:360px;">
    <div class="modal-header">
      <div class="modal-title">⋯ Acciones de Cuenta</div>
      <button class="modal-close" onclick="closeModal('modal-acciones-cuenta')">✕</button>
    </div>
    <div class="modal-body" style="padding:0.5rem 0;gap:0;">
      <button class="menu-action-btn" onclick="closeModal('modal-acciones-cuenta');openModal('modal-ver-cuenta')">👁 Ver detalle completo</button>
      <button class="menu-action-btn" onclick="closeModal('modal-acciones-cuenta');openModal('modal-editar-cuenta')">✏️ Editar cuenta</button>
      <button class="menu-action-btn" onclick="closeModal('modal-acciones-cuenta');openModal('modal-contacto')">👤 Agregar contacto</button>
      <button class="menu-action-btn" onclick="closeModal('modal-acciones-cuenta');openModal('modal-oportunidad')">💼 Nueva oportunidad</button>
      <button class="menu-action-btn" onclick="closeModal('modal-acciones-cuenta');openModal('modal-actividad')">✅ Crear actividad</button>
      <div style="border-top:1px solid var(--border);margin:0.4rem 0;"></div>
      <button class="menu-action-btn">📤 Exportar datos</button>
      <button class="menu-action-btn" style="color:var(--danger);" onclick="closeModal('modal-acciones-cuenta');openModal('modal-confirm-eliminar-cuenta')">🗑 Eliminar cuenta</button>
    </div>
  </div>
</div>

<!-- Modal: Confirmar Eliminar Cuenta -->
<div class="modal-overlay" id="modal-confirm-eliminar-cuenta">
  <div class="modal" style="max-width:400px;">
    <div class="modal-header">
      <div class="modal-title" style="color:var(--danger);">⚠️ Eliminar Cuenta</div>
      <button class="modal-close" onclick="closeModal('modal-confirm-eliminar-cuenta')">✕</button>
    </div>
    <div class="modal-body">
      <p style="font-size:0.875rem;">¿Eliminar esta cuenta? Se perderán todos sus contactos, oportunidades y el historial de actividades asociados.</p>
    </div>
    <div class="modal-footer">
      <button class="btn btn-secondary btn-sm" onclick="closeModal('modal-confirm-eliminar-cuenta')">Cancelar</button>
      <button class="btn btn-danger btn-sm">🗑 Sí, eliminar</button>
    </div>
  </div>
</div>

<!-- Modal: Nueva Cuenta -->
<div class="modal-overlay" id="modal-cuenta">
  <div class="modal">
    <div class="modal-header">
      <div class="modal-title">🏢 Nueva Cuenta</div>
      <button class="modal-close" onclick="closeModal('modal-cuenta')">✕</button>
    </div>
    <div class="modal-body">
      <div class="form-group">
        <label>Nombre de la empresa</label>
        <input class="form-control" type="text" placeholder="Ej: Tecno S.A.">
      </div>
      <div class="form-row">
        <div class="form-group">
          <label>Industria</label>
          <select class="form-control">
            <option>Tecnología</option>
            <option>Manufactura</option>
            <option>Retail</option>
            <option>Finanzas</option>
            <option>Salud</option>
            <option>Educación</option>
            <option>Logística</option>
            <option>Otro</option>
          </select>
        </div>
        <div class="form-group">
          <label>Tipo</label>
          <select class="form-control">
            <option>Cliente</option>
            <option>Prospecto</option>
            <option>Lead</option>
            <option>Partner</option>
          </select>
        </div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label>Email</label>
          <input class="form-control" type="email" placeholder="contacto@empresa.com">
        </div>
        <div class="form-group">
          <label>Teléfono</label>
          <input class="form-control" type="tel" placeholder="+57 1 000 0000">
        </div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label>Sitio web</label>
          <input class="form-control" type="url" placeholder="https://empresa.com">
        </div>
        <div class="form-group">
          <label>Ciudad</label>
          <input class="form-control" type="text" placeholder="Bogotá">
        </div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label>Potencial de ingresos</label>
          <input class="form-control" type="text" placeholder="$0">
        </div>
        <div class="form-group">
          <label>Responsable</label>
          <select class="form-control">
            <option>Carlos V.</option>
            <option>María P.</option>
            <option>Luis A.</option>
            <option>Ana R.</option>
          </select>
        </div>
      </div>
    </div>
    <div class="modal-footer">
      <button class="btn btn-secondary btn-sm" onclick="closeModal('modal-cuenta')">Cancelar</button>
      <button class="btn btn-primary btn-sm">Guardar Cuenta</button>
    </div>
  </div>
</div>

