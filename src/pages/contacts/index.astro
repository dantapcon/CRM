---
import CRMLayout from '../../layouts/CRMLayout.astro';

const contacts = [
  { id:1,  name:'Carlos Ruiz',       company:'Tecno S.A.',     role:'Director Comercial', email:'c.ruiz@tecno.com',       phone:'+57 300 111 2222', status:'Cliente',    score:92, last:'Hace 1h'  },
  { id:2,  name:'Ana López',         company:'Global Corp',    role:'Gerente de Compras', email:'alopez@globalcorp.com',   phone:'+57 310 222 3333', status:'Cliente',    score:88, last:'Ayer'     },
  { id:3,  name:'Mario Torres',      company:'NetSol Ltda.',   role:'CEO',                email:'m.torres@netsol.co',     phone:'+57 320 333 4444', status:'Prospecto',  score:74, last:'3 días'   },
  { id:4,  name:'Lucía Herrera',     company:'DataPoint S.A.', role:'CTO',                email:'lherrera@datapoint.com', phone:'+57 315 444 5555', status:'Lead',       score:61, last:'1 semana' },
  { id:5,  name:'Pedro Mendoza',     company:'MegaTrade',      role:'Director TI',        email:'pmendoza@megatrade.co',  phone:'+57 300 555 6666', status:'Cliente',    score:95, last:'2h'       },
  { id:6,  name:'Sandra Gómez',      company:'SoftCo',         role:'VP Ventas',          email:'sgomez@softco.com',      phone:'+57 321 666 7777', status:'Inactivo',   score:40, last:'1 mes'    },
  { id:7,  name:'Felipe Castro',     company:'InnoTech',       role:'Gerente Financiero', email:'fcastro@innotech.io',    phone:'+57 317 777 8888', status:'Prospecto',  score:70, last:'4 días'   },
  { id:8,  name:'Valentina Ramos',   company:'Logística Plus', role:'Directora General',  email:'vramos@logplus.com',     phone:'+57 312 888 9999', status:'Lead',       score:55, last:'2 semanas'},
  { id:9,  name:'Andrés Silva',      company:'FinGroup',       role:'CFO',                email:'asilva@fingroup.co',     phone:'+57 318 999 0000', status:'Cliente',    score:87, last:'1 día'    },
  { id:10, name:'Carolina Morales',  company:'Retail Max',     role:'Directora Marketing',email:'cmorales@retailmax.com', phone:'+57 305 000 1111', status:'Prospecto',  score:68, last:'5 días'   },
];

const statusMap: Record<string,string> = {
  'Cliente':   'badge-green',
  'Prospecto': 'badge-blue',
  'Lead':      'badge-yellow',
  'Inactivo':  'badge-gray',
};
---
<CRMLayout title="Contactos">

  <div class="page-header">
    <div>
      <h1 class="page-title">Contactos</h1>
      <p class="page-subtitle">Gestión de personas y relaciones individuales</p>
    </div>
    <div class="gap-actions">
      <button class="btn btn-secondary btn-sm">📤 Importar</button>
      <button class="btn btn-secondary btn-sm">📥 Exportar</button>
      <a href="/contacts/new" class="btn btn-primary btn-sm">+ Nuevo Contacto</a>
    </div>
  </div>

  <!-- KPIs -->
  <div class="kpi-grid" style="grid-template-columns:repeat(4,1fr);margin-bottom:1.5rem;">
    <div class="kpi-card kpi-blue">
      <div class="kpi-value">1,248</div>
      <div class="kpi-label">Total Contactos</div>
      <div class="kpi-change up">↑ 24 este mes</div>
    </div>
    <div class="kpi-card kpi-green">
      <div class="kpi-value">523</div>
      <div class="kpi-label">Clientes</div>
      <div class="kpi-change up">↑ 8 nuevos</div>
    </div>
    <div class="kpi-card kpi-gold">
      <div class="kpi-value">384</div>
      <div class="kpi-label">Prospectos</div>
      <div class="kpi-change flat">→ Sin cambio</div>
    </div>
    <div class="kpi-card kpi-orange">
      <div class="kpi-value">341</div>
      <div class="kpi-label">Leads</div>
      <div class="kpi-change up">↑ 16 nuevos</div>
    </div>
  </div>

  <!-- Toolbar -->
  <div class="toolbar">
    <div class="search-input-wrap">
      <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
      </svg>
      <input class="search-input" type="text" placeholder="Buscar contacto…">
    </div>
    <select class="form-control" style="width:auto;padding:0.47rem 0.75rem;">
      <option>Todos los estados</option>
      <option>Cliente</option>
      <option>Prospecto</option>
      <option>Lead</option>
      <option>Inactivo</option>
    </select>
    <select class="form-control" style="width:auto;padding:0.47rem 0.75rem;">
      <option>Todas las empresas</option>
      <option>Tecno S.A.</option>
      <option>Global Corp</option>
    </select>
    <select class="form-control" style="width:auto;padding:0.47rem 0.75rem;">
      <option>Ordenar: Nombre</option>
      <option>Ordenar: Empresa</option>
      <option>Ordenar: Score</option>
      <option>Ordenar: Última actividad</option>
    </select>
    <div class="spacer"></div>
    <button class="btn btn-ghost btn-sm">⊞ Tarjetas</button>
    <button class="btn btn-ghost btn-sm btn-icon" style="background:#f1f5f9;">☰</button>
  </div>

  <!-- Table -->
  <div class="card">
    <div style="overflow-x:auto;">
      <table class="data-table">
        <thead>
          <tr>
            <th><input type="checkbox"></th>
            <th>Nombre</th>
            <th>Empresa</th>
            <th>Cargo</th>
            <th>Email</th>
            <th>Teléfono</th>
            <th>Estado</th>
            <th>Score</th>
            <th>Última Act.</th>
            <th>Acciones</th>
          </tr>
        </thead>
        <tbody>
          {contacts.map(c => (
            <tr>
              <td><input type="checkbox"></td>
              <td>
                <div style="display:flex;align-items:center;gap:0.6rem;">
                  <div class="avatar">{c.name.split(' ').map(n=>n[0]).join('').slice(0,2)}</div>
                  <a href={`/contacts/${c.id}`} style="font-weight:600;color:var(--primary);text-decoration:none;">{c.name}</a>
                </div>
              </td>
              <td><a href="/accounts" style="color:var(--primary-light);text-decoration:none;">{c.company}</a></td>
              <td class="text-muted">{c.role}</td>
              <td style="font-size:0.75rem;">{c.email}</td>
              <td style="font-size:0.75rem;">{c.phone}</td>
              <td><span class={`badge ${statusMap[c.status]}`}>{c.status}</span></td>
              <td>
                <div style="display:flex;align-items:center;gap:0.4rem;">
                  <div class="progress-bar" style="width:60px;">
                    <div class="progress-fill" style={`width:${c.score}%;background:${c.score>=80?'var(--success)':c.score>=60?'var(--warning)':'var(--danger)'}`}></div>
                  </div>
                  <span style="font-size:0.72rem;font-weight:600;">{c.score}</span>
                </div>
              </td>
              <td class="text-muted text-xs">{c.last}</td>
              <td>
                <div class="gap-actions">
                  <button class="btn btn-ghost btn-sm btn-icon" title="Llamar">📞</button>
                  <button class="btn btn-ghost btn-sm btn-icon" title="Email">📧</button>
                  <button class="btn btn-ghost btn-sm btn-icon" title="Ver">👁</button>
                  <button class="btn btn-ghost btn-sm btn-icon" title="Más">⋯</button>
                </div>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
    <!-- Pagination -->
    <div style="display:flex;align-items:center;justify-content:space-between;padding:0.875rem 1.25rem;border-top:1px solid var(--border);">
      <span class="text-muted text-xs">Mostrando 1-10 de 1,248 contactos</span>
      <div class="gap-actions">
        <button class="btn btn-secondary btn-sm">← Anterior</button>
        <button class="btn btn-primary btn-sm">1</button>
        <button class="btn btn-secondary btn-sm">2</button>
        <button class="btn btn-secondary btn-sm">3</button>
        <span class="text-muted">...</span>
        <button class="btn btn-secondary btn-sm">125</button>
        <button class="btn btn-secondary btn-sm">Siguiente →</button>
      </div>
    </div>
  </div>

</CRMLayout>
